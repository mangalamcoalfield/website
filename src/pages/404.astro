---
import Site from '../layouts/Site.astro';
---
<Site title="Page not found" description="The page you were looking for could not be found.">
  <section class="relative flex min-h-[80vh] items-center overflow-hidden bg-background pt-24">
    <div class="pointer-events-none absolute inset-0" aria-hidden="true" style="background:radial-gradient(50% 60% at 50% 20%, rgba(21,48,31,.6), transparent 70%), radial-gradient(40% 40% at 70% 90%, rgba(174,207,62,.1), transparent 70%)"></div>
    <div class="relative mx-auto max-w-3xl px-6 text-center">
      <span class="text-[11px] font-semibold uppercase tracking-[0.28em] text-primary">Error 404</span>
      <h1 class="mt-4 font-[var(--font-display)] text-5xl font-bold tracking-tight text-foreground md:text-7xl">This page isn't here.</h1>
      <p class="mx-auto mt-6 max-w-xl text-lg text-muted-foreground">The page you were looking for could not be found. It may have moved, or the link may be out of date.</p>
      <div class="mt-9 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/" class="rounded-full bg-primary px-7 py-3.5 text-sm font-semibold text-primary-foreground shadow-[0_0_45px_-6px_hsl(var(--primary)/0.7)] transition-transform hover:scale-[1.03]">Back to home</a>
        <a href="/learn" class="rounded-full border border-white/15 bg-white/[0.04] px-7 py-3.5 text-sm font-semibold text-foreground transition-colors hover:border-primary hover:text-primary">Knowledge hub →</a>
      </div>
    </div>
  </section>
</Site>
