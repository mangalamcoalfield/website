---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
---
<Base title="Safety & Compliance" description="DGMS focus, statutory positions, registers, gas and ventilation discipline, and workforce medicals — how Mangalam treats statutory safety as the condition for permission to operate.">
  <PageHero
    eyebrow="Safety & compliance"
    title="The condition for permission to operate."
    underline="permission to operate."
    lead="Underground coal mining carries real risk. We treat statutory safety as the baseline, not an afterthought — and as the condition for our permission to operate."
  />

  <section class="block on-forest">
    <div class="wrap">
      <div class="split">
        <div class="reveal">
          <span class="eyebrow">Our standard</span>
          <h2 style="margin-top:20px">Statutory safety, every shift.</h2>
          <p class="lead" style="margin-top:20px">The Directorate General of Mines Safety (DGMS) sets the framework for Indian coal mining. We operate within it as a minimum.</p>
          <ul class="checklist">
            <li><svg class="ck" viewBox="0 0 24 24"><use href="#check"/></svg>Qualified statutory officials across all DGMS-mandated positions</li>
            <li><svg class="ck" viewBox="0 0 24 24"><use href="#check"/></svg>Maintained statutory registers and periodic equipment testing</li>
            <li><svg class="ck" viewBox="0 0 24 24"><use href="#check"/></svg>Gas monitoring, ventilation discipline, and roof-support standards</li>
            <li><svg class="ck" viewBox="0 0 24 24"><use href="#check"/></svg>Medical examinations and competency tracking for the workforce</li>
          </ul>
        </div>
        <div class="metric reveal">
          <div class="big">Zero</div>
          <div class="cap">compromise on the standards that keep people safe underground.</div>
        </div>
      </div>
    </div>
  </section>

  <section class="block on-near">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow">How it works in practice</span>
        <h2>The pillars of our safety system.</h2>
        <p class="lead">A plain summary of the statutory disciplines that govern underground operations. Detailed write-ups will be published from the content track.</p>
      </div>
      <div class="cards stagger reveal">
        <div class="card"><span class="ix">01</span><h3>Statutory positions</h3><p>DGMS-mandated officials — manager, safety officer, surveyors and engineers — appointed and certified for every district.</p></div>
        <div class="card"><span class="ix">02</span><h3>Registers &amp; records</h3><p>Statutory registers maintained and equipment tested on schedule, with structured reporting.</p></div>
        <div class="card"><span class="ix">03</span><h3>Gas &amp; ventilation</h3><p>Ventilation discipline and gas monitoring keep the air safe underground. (We teach the science publicly; we never publish site-specific readings.)</p></div>
        <div class="card"><span class="ix">04</span><h3>Workforce medicals</h3><p>Periodic medical examinations and competency tracking for own and contractor labour.</p></div>
      </div>
      <div class="reveal" style="margin-top:48px">
        <a class="tlink" href="/learn/dgms-and-the-rules-of-the-mine">Learn about DGMS &amp; the rules of the mine <svg width="18" height="18"><use href="#arrow"/></svg></a>
      </div>
    </div>
  </section>
</Base>
