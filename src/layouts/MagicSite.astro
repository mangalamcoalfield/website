---
// MagicSite — shared shell for the Magic × Pro Max multi-page mirror.
// Green/lime on coal-black, Tailwind + magic.css. Glass nav, scroll-progress
// bar, footer, mirror badge. Page content is composed of Magic React islands.
import '@fontsource/archivo/600.css';
import '@fontsource/archivo/700.css';
import '@fontsource/hanken-grotesk/400.css';
import '@fontsource/hanken-grotesk/500.css';
import '@fontsource/hanken-grotesk/600.css';
import '../styles/magic.css';
import { SITE } from '../data/site';

interface Props { title?: string; description?: string; }
const { title, description = SITE.description } = Astro.props;
const full = title ? `${title} · ${SITE.name}` : `${SITE.name} — Magic mirror`;
const base = '/mirror';
const path = Astro.url.pathname;
const nav = [
  { href: `${base}/about`, label: 'About' },
  { href: `${base}/operations`, label: 'Operations' },
  { href: `${base}/safety`, label: 'Safety' },
  { href: `${base}/learn`, label: 'Learn' },
  { href: `${base}/cares`, label: 'Cares' },
  { href: `${base}/careers`, label: 'Careers' },
  { href: `${base}/contact`, label: 'Contact' },
];
const active = (h: string) => path === h || (h !== base && path.startsWith(h));
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{full}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="noindex" />
  <link rel="icon" type="image/png" href="/mangalam_logo.png" />
  <meta name="theme-color" content="#06100b" />
</head>
<body class="bg-background text-foreground antialiased">
  <!-- scroll progress -->
  <div id="prog" class="fixed inset-x-0 top-0 z-[1100] h-[3px] origin-left scale-x-0 bg-gradient-to-r from-primary/40 via-primary to-secondary"></div>

  <!-- glass nav -->
  <header id="mh" class="fixed inset-x-0 top-0 z-[1000] transition-all duration-300">
    <div class="mx-auto max-w-6xl px-4">
      <div id="mnav" class="mt-3 flex h-16 items-center justify-between rounded-2xl px-4 transition-all duration-300">
        <a href={base} class="flex items-center gap-2" aria-label="Home"><img src="/mangalam_logo.png" alt={SITE.name} width="150" height="38" class="h-9 w-auto" /></a>
        <nav class="hidden items-center gap-7 md:flex">
          {nav.map((i) => (
            <a href={i.href} class:list={["text-sm transition-colors hover:text-foreground", active(i.href) ? "text-foreground" : "text-muted-foreground"]}>{i.label}</a>
          ))}
        </nav>
        <a href={SITE.portalUrl} rel="noopener" class="hidden rounded-xl border border-white/15 bg-white/[0.04] px-4 py-2 text-[13px] font-semibold text-foreground transition-colors hover:border-primary hover:text-primary md:inline-block">Employee Portal <svg width="11" height="11" viewBox="0 0 24 24" fill="none" class="ml-0.5 inline-block align-[-1px]" aria-hidden="true"><path d="M7 17 17 7M9 7h8v8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        <button id="mb" class="flex flex-col gap-[5px] p-2 md:hidden" aria-label="Menu" aria-expanded="false">
          <span class="block h-0.5 w-5 bg-foreground"></span><span class="block h-0.5 w-5 bg-foreground"></span><span class="block h-0.5 w-5 bg-foreground"></span>
        </button>
      </div>
    </div>
  </header>

  <nav id="mm" class="fixed inset-0 z-[999] flex translate-x-full flex-col justify-center gap-1 bg-background/95 px-9 backdrop-blur-lg transition-transform duration-300 md:hidden">
    {nav.map((i) => <a href={i.href} class="border-b border-white/10 py-3 font-[var(--font-display)] text-2xl font-semibold">{i.label}</a>)}
    <a href={SITE.portalUrl} rel="noopener" class="mt-4 font-[var(--font-display)] text-2xl font-semibold text-primary">Employee Portal <svg width="11" height="11" viewBox="0 0 24 24" fill="none" class="ml-0.5 inline-block align-[-1px]" aria-hidden="true"><path d="M7 17 17 7M9 7h8v8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="border-t border-white/10 bg-white/[0.015] py-16 backdrop-blur-sm">
    <div class="mx-auto grid max-w-6xl grid-cols-2 gap-10 px-6 md:grid-cols-4">
      <div class="col-span-2 md:col-span-1">
        <img src="/mangalam_logo.png" alt={SITE.name} width="200" height="50" class="mb-4 h-12 w-auto" />
        <p class="max-w-xs text-sm leading-relaxed text-muted-foreground">{SITE.legalName} — Mine Developer &amp; Operator, Amlabad Colliery, Eastern Jharia, Jharkhand.</p>
      </div>
      <div>
        <h4 class="mb-4 text-[11px] font-semibold uppercase tracking-[0.12em] text-muted-foreground">Company</h4>
        {[['About','/about'],['Operations','/operations'],['Safety','/safety'],['Mangalam Cares','/cares'],['Careers','/careers']].map(([l,h]) => (
          <a href={`${base}${h}`} class="mb-2.5 block text-sm text-foreground/80 transition-colors hover:text-primary">{l}</a>
        ))}
      </div>
      <div>
        <h4 class="mb-4 text-[11px] font-semibold uppercase tracking-[0.12em] text-muted-foreground">Knowledge</h4>
        <a href={`${base}/learn`} class="mb-2.5 block text-sm text-foreground/80 transition-colors hover:text-primary">How mining works</a>
        <a href={`${base}/contact`} class="mb-2.5 block text-sm text-foreground/80 transition-colors hover:text-primary">Contact</a>
      </div>
      <div>
        <h4 class="mb-4 text-[11px] font-semibold uppercase tracking-[0.12em] text-muted-foreground">Contact</h4>
        <a href={`mailto:${SITE.hrEmail}`} class="mb-2.5 block text-sm text-foreground/80 transition-colors hover:text-primary">{SITE.hrEmail}</a>
        <a href={SITE.portalUrl} rel="noopener" class="mb-2.5 block text-sm text-foreground/80 transition-colors hover:text-primary">Employee Portal <svg width="11" height="11" viewBox="0 0 24 24" fill="none" class="ml-0.5 inline-block align-[-1px]" aria-hidden="true"><path d="M7 17 17 7M9 7h8v8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
      </div>
    </div>
    <div class="mx-auto mt-12 flex max-w-6xl flex-wrap justify-between gap-3 border-t border-white/10 px-6 pt-6 text-[13px] text-muted-foreground">
      <span>© 2026 {SITE.legalName}</span>
      <span>Design mirror · Magic × UI-UX Pro Max concept · not the live site</span>
    </div>
  </footer>

  <a href="/" class="fixed bottom-4 right-4 z-[1300] rounded-full bg-gradient-to-b from-[#d6e98a] to-[#aecf3e] px-3.5 py-1.5 text-[11px] font-bold text-[#10130d] shadow-[0_8px_28px_rgba(174,207,62,.3)]">⚡ back to live site</a>

  <script>
    const mh = document.getElementById('mh');
    const mnav = document.getElementById('mnav');
    const prog = document.getElementById('prog');
    const onScroll = () => {
      const y = window.scrollY;
      const scrolled = y > 24;
      mnav?.classList.toggle('bg-background/60', scrolled);
      mnav?.classList.toggle('border', scrolled);
      mnav?.classList.toggle('border-white/10', scrolled);
      mnav?.classList.toggle('backdrop-blur-xl', scrolled);
      mnav?.classList.toggle('shadow-[0_18px_50px_-20px_rgba(0,0,0,.8)]', scrolled);
      const h = document.documentElement.scrollHeight - window.innerHeight;
      if (prog) prog.style.transform = `scaleX(${h > 0 ? y / h : 0})`;
    };
    addEventListener('scroll', onScroll, { passive: true }); onScroll();
    const mb = document.getElementById('mb'); const mm = document.getElementById('mm');
    mb?.addEventListener('click', () => {
      const open = mm?.classList.toggle('translate-x-full');
      mb.setAttribute('aria-expanded', String(open === false));
      document.body.style.overflow = open === false ? 'hidden' : '';
    });
    mm?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => { mm.classList.add('translate-x-full'); document.body.style.overflow=''; }));
  </script>
</body>
</html>
