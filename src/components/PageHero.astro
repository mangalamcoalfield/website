---
interface Props {
  eyebrow: string;
  title: string;
  lead?: string;
  /** Word(s) in the title to underline in lime, matched verbatim. */
  underline?: string;
}
const { eyebrow, title, lead, underline } = Astro.props;

// Split the title around the underlined fragment (if any) for the lime accent.
let before = title, mark = '', after = '';
if (underline && title.includes(underline)) {
  const i = title.indexOf(underline);
  before = title.slice(0, i);
  mark = underline;
  after = title.slice(i + underline.length);
}
---
<section class="page-hero">
  <div class="wrap">
    <span class="eyebrow reveal in">{eyebrow}</span>
    <h1 class="reveal in">{before}{mark && <span class="u">{mark}</span>}{after}</h1>
    {lead && <p class="lead reveal in">{lead}</p>}
  </div>
</section>
