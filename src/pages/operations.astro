---
import Site from '../layouts/Site.astro';
import ShaderHero from '../components/magic/ShaderHero.tsx';
import PitMap from '../components/magic/PitMap.tsx';
import MagicBento from '../components/magic/MagicBento.tsx';
import { Lines } from '../components/magic/MagicSections.tsx';
---
<Site title="Operations & Capabilities" description="Mangalam's two commercial lines — underground coal across all four Amlabad pits, and coal bed methane — run under one operator in Eastern Jharia.">
  <ShaderHero
    client:load
    compact
    eyebrow="Operations & capabilities"
    title="Two operations, one operator"
    accentWords={2}
    description="Through the Amlabad block in Eastern Jharia, Jharkhand, Mangalam runs two commercial lines — underground coal across all four pits, and the coal bed methane held within the same seams — all under one operator."
    primary={{ label: 'Safety & compliance', href: '/safety' }}
  />

  <section class="relative bg-background py-16">
    <div class="mx-auto max-w-6xl px-6">
      <div class="max-w-3xl">
        <span class="text-[11px] font-semibold uppercase tracking-[0.28em] text-primary">How the coal is mined</span>
        <h2 class="mt-3 font-[var(--font-display)] text-4xl font-bold tracking-tight text-foreground md:text-5xl">Prime coking coal, won underground.</h2>
        <p class="mt-4 text-[17px] leading-8 text-muted-foreground">The Amlabad block lies in the Jharia Coalfield — India's principal source of prime coking coal — within the Gondwana Barakar coal measures of the Damodar Valley. The coal is won underground by the bord-and-pillar method, and seam for seam it is prized washery-grade coking coal, the raw material of steel-making. The same seams hold coal bed methane; capturing it improves safety underground and adds a second energy stream. Every part of the work runs to the statutory rulebook — the Mines Act, the Coal Mines Regulations 2017 and DGMS oversight.</p>
      </div>
      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <a href="/learn/bord-and-pillar-mining" class="group rounded-2xl border border-white/10 bg-white/[0.04] p-6 transition-all hover:-translate-y-1 hover:border-primary/30">
          <div class="font-[var(--font-display)] text-lg font-semibold text-foreground">Bord &amp; pillar</div>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">How underground coal is won in galleries and pillars — and the ground kept stable.</p>
          <span class="mt-3 inline-block text-[13px] font-semibold text-primary">How it works →</span>
        </a>
        <a href="/learn/coking-coal-and-coal-grades" class="group rounded-2xl border border-white/10 bg-white/[0.04] p-6 transition-all hover:-translate-y-1 hover:border-primary/30">
          <div class="font-[var(--font-display)] text-lg font-semibold text-foreground">Prime coking coal</div>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">Washery grades W-I and W-II, and why prime coking coal is the raw material of steel.</p>
          <span class="mt-3 inline-block text-[13px] font-semibold text-primary">Coal &amp; grades →</span>
        </a>
        <a href="/learn/coal-bed-methane-explained" class="group rounded-2xl border border-white/10 bg-white/[0.04] p-6 transition-all hover:-translate-y-1 hover:border-primary/30">
          <div class="font-[var(--font-display)] text-lg font-semibold text-foreground">Coal bed methane</div>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">The gas held in the seams — a safety measure and a second energy stream.</p>
          <span class="mt-3 inline-block text-[13px] font-semibold text-primary">The science →</span>
        </a>
        <a href="/learn/dgms-and-the-rules-of-the-mine" class="group rounded-2xl border border-white/10 bg-white/[0.04] p-6 transition-all hover:-translate-y-1 hover:border-primary/30">
          <div class="font-[var(--font-display)] text-lg font-semibold text-foreground">Run to the rulebook</div>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">The Mines Act, CMR 2017 and DGMS — the statutory framework every mine works under.</p>
          <span class="mt-3 inline-block text-[13px] font-semibold text-primary">The framework →</span>
        </a>
      </div>
    </div>
  </section>

  <Lines client:visible />
  <PitMap client:visible />
  <MagicBento client:visible />
</Site>
