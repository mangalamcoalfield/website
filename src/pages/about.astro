---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
---
<Base title="About & Leadership" description="The Mangalam Coalfield story — a foundation of rich legacy, resilience and shared values, and the leadership carrying it forward.">
  <PageHero
    eyebrow="About Mangalam"
    title="A foundation built to last."
    underline="last."
    lead="Mangalam Coalfield Private Limited is a mine developer and operator reviving the historic Amlabad pits in Eastern Jharia, Jharkhand — built on legacy, run to standard, and committed to responsible coal and cleaner energy."
  />

  <section class="block on-near">
    <div class="wrap">
      <div class="duo">
        <div class="reveal">
          <span class="eyebrow">Our story</span>
          <h2 style="margin-top:18px">Carrying a vision forward.</h2>
          <div class="prose" style="margin-top:24px">
            <p>Mangalam stands on a foundation of rich legacy, resilience, and shared values — carrying forward the vision of its founder. A new generation now leads, committed to trust, integrity, and excellence in all it builds.</p>
            <p>Today, that commitment is expressed through the revival of the Amlabad block in Eastern Jharia: restoring historic underground coal workings and developing coal bed methane as a cleaner commercial energy stream from the same seams.</p>
            <p>The company operates to the Coal Mines Regulations 2017 and the Mines Act 1952, with qualified statutory officials in every mandated position. <em>(Placeholder copy — the full company history will be filled in from the content track.)</em></p>
          </div>
        </div>

        <!-- Chairman Emeritus tribute with portrait slot -->
        <div class="reveal">
          <span class="eyebrow">In memoriam</span>
          <div class="portrait-card" style="margin-top:18px">
            <div class="portrait-slot">
              Portrait of Late Shree Gopal Agarwal<br />— to be supplied —
            </div>
            <div class="meta">
              <div class="name">Late Shree Gopal Agarwal</div>
              <div class="role">Chairman Emeritus</div>
              <p style="font-style:italic">Guided by his visionary leadership, the Mangalam family remains deeply committed to upholding trust, integrity, and excellence — the values on which the company was built and continues to grow.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="block on-forest">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow">What guides us</span>
        <h2>Trust, integrity, excellence.</h2>
        <p class="lead">The values carried forward by a new generation of leadership.</p>
      </div>
      <div class="cards stagger reveal">
        <div class="card"><span class="ix">01</span><h3>Trust</h3><p>Earned through consistency — with our workforce, our partners, and the communities around the mine.</p></div>
        <div class="card"><span class="ix">02</span><h3>Integrity</h3><p>Operating to statute and to our word, with safety and compliance treated as the baseline.</p></div>
        <div class="card"><span class="ix">03</span><h3>Excellence</h3><p>Engineering rigour and discipline on every shift, underground and above ground.</p></div>
      </div>
    </div>
  </section>

  <section class="block on-near">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow">Leadership</span>
        <h2>The team taking it forward.</h2>
        <p class="lead">Current leadership profiles will be published here from the content track.</p>
      </div>
      <div class="leaders reveal">
        <div class="leader"><div class="name">Leadership profile</div><div class="role">Director</div><p>Profile and bio to be supplied.</p></div>
        <div class="leader"><div class="name">Leadership profile</div><div class="role">Director</div><p>Profile and bio to be supplied.</p></div>
        <div class="leader"><div class="name">Leadership profile</div><div class="role">Statutory Head</div><p>Profile and bio to be supplied.</p></div>
      </div>
    </div>
  </section>
</Base>
