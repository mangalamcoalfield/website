---
import Base from '../layouts/Base.astro';
---
<Base title="Page not found" description="The page you were looking for could not be found.">
  <section class="page-hero" style="min-height:70vh;display:flex;align-items:center">
    <div class="wrap">
      <span class="eyebrow reveal in">Error 404</span>
      <h1 class="reveal in">This page isn't here.</h1>
      <p class="lead reveal in">The page you were looking for could not be found. It may have moved, or the link may be out of date.</p>
      <div class="hero-cta reveal in">
        <a class="btn btn-primary" href="/">Back to home</a>
        <a class="tlink" href="/learn">Knowledge hub <svg width="18" height="18"><use href="#arrow"/></svg></a>
      </div>
    </div>
  </section>
</Base>
