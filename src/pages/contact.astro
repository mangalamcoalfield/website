---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import ContactForm from '../components/ContactForm.astro';
import { SITE } from '../data/site';
---
<Base title="Contact" description="Get in touch with Mangalam Coalfield Private Limited — enquiries, partnerships, and general contact.">
  <PageHero
    eyebrow="Contact"
    title="Get in touch."
    underline="touch."
    lead="For enquiries, partnerships or general questions, send us a message and we will be in touch."
  />

  <section class="block on-near">
    <div class="wrap">
      <div class="duo">
        <div class="reveal">
          <span class="eyebrow">Send a message</span>
          <h2 style="margin:18px 0 28px">We read every enquiry.</h2>
          <ContactForm />
        </div>
        <div class="reveal">
          <span class="eyebrow">Reach us</span>
          <div class="prose" style="margin-top:18px">
            <h3>Operations</h3>
            <p>{SITE.location}</p>
            <h3>Registered office</h3>
            <p>{SITE.regOffice.replace('Registered office · ', '')}</p>
            <h3>Email</h3>
            <p><a href={`mailto:${SITE.hrEmail}`}>{SITE.hrEmail}</a></p>
            <h3>Employees</h3>
            <p><a href={SITE.portalUrl} rel="noopener">Employee Portal ↗</a></p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
