---
import MagicSite from '../../layouts/MagicSite.astro';
import ShaderHero from '../../components/magic/ShaderHero.tsx';

const programmes = [
  {
    status: 'Completed',
    title: 'Community welfare',
    body: 'Local engagement and welfare initiatives in the villages around the Amlabad block — putting the people who live alongside the mine first.',
  },
  {
    status: 'Completed',
    title: 'Skill & safety training',
    body: 'Investment in workforce training and safety awareness for own and contractor labour, building capability that lasts beyond a single shift.',
  },
  {
    status: 'Planned',
    title: 'Green cover & reclamation',
    body: 'Plantation and land-care contributions in the mine vicinity — restoring the ground we operate on as work moves through the lease.',
  },
  {
    status: 'Planned',
    title: 'Water & environment',
    body: 'Responsible water management and dust-control measures around the mine, keeping the land and the people who depend on it at the centre.',
  },
];
---
<MagicSite title="Mangalam Cares">
  <ShaderHero
    client:load
    compact
    eyebrow="Mangalam Cares"
    title="The work above ground matters too"
    accentWords={2}
    description="Beyond production, Mangalam invests in the people and the environment around the mine — community welfare and the land we operate on. We showcase our own contributions: completed work with evidence, and planned work clearly labelled."
  />

  <section class="relative bg-background py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-12 max-w-2xl">
        <span class="mb-4 inline-block text-[11px] font-semibold uppercase tracking-[0.2em] text-primary">Our contributions</span>
        <h2 class="font-[var(--font-display)] text-3xl font-bold tracking-tight text-foreground sm:text-4xl">Completed work, shown with evidence.</h2>
        <p class="mt-4 text-base leading-relaxed text-muted-foreground">A focused set of programmes — community welfare and skills training already underway, with green cover and water management planned next. Completed work carries evidence; planned work is labelled as such.</p>
      </div>

      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
        {programmes.map((p) => (
          <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-7 backdrop-blur-sm transition hover:border-primary/30">
            {p.status === 'Completed' ? (
              <span class="mb-4 inline-block rounded-full bg-primary/15 px-3 py-1 text-[11px] font-semibold uppercase tracking-wide text-primary">Completed</span>
            ) : (
              <span class="mb-4 inline-block rounded-full bg-secondary/15 px-3 py-1 text-[11px] font-semibold uppercase tracking-wide text-secondary">Planned</span>
            )}
            <h3 class="font-[var(--font-display)] text-lg font-semibold text-foreground">{p.title}</h3>
            <p class="mt-2 text-sm text-muted-foreground">{p.body}</p>
          </div>
        ))}
      </div>

      <p class="mt-12 max-w-3xl text-sm text-muted-foreground">
        Placeholder programmes shown, pending the content track. The framing stays the same: our own contributions — completed work shown with evidence, planned work clearly labelled.
      </p>
    </div>
  </section>
</MagicSite>
