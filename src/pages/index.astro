---
import Site from '../layouts/Site.astro';
import ShaderHero from '../components/magic/ShaderHero.tsx';
import MagicBento from '../components/magic/MagicBento.tsx';
import ScrollScene from '../components/magic/ScrollScene.tsx';
import { Stats, Lines, Safety, CTA } from '../components/magic/MagicSections.tsx';
import { SITE } from '../data/site';
import { safeSelect, type Regulation } from '../lib/supabase';
import LatestTicker from '../components/LatestTicker.astro';

const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE.legalName,
  url: 'https://mangalamcoal.com',
  logo: 'https://mangalamcoal.com/mangalam_logo.png',
  description: SITE.description,
  email: SITE.hrEmail,
  telephone: '+919288276733',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Amlabad Colliery, Amlabad (PO), Eastern Jharia',
    addressLocality: 'District Bokaro',
    addressRegion: 'Jharkhand',
    addressCountry: 'IN',
  },
  contactPoint: [
    { '@type': 'ContactPoint', telephone: '+919288276733', contactType: 'customer service', email: SITE.hrEmail, areaServed: 'IN' },
  ],
};

// Latest DGMS circulars/notifications for the home ticker.
const MON = ['', 'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
const latestRegs = await safeSelect<Regulation>((c) =>
  c.from('regulations').select('slug,title,issued_date,category').eq('published', true)
    .in('category', ['dgms_circular', 'dgms_notification'])
    .not('issued_date', 'is', null)
    .order('issued_date', { ascending: false, nullsFirst: false }).limit(20)
);
const tickerItems = latestRegs
  .filter((r) => !!r.issued_date && /^\d{4}-\d{2}-\d{2}/.test(r.issued_date as string))
  .slice(0, 8)
  .map((r) => { const [y, m] = (r.issued_date as string).split('-'); return { title: r.title, href: `/regulations/${r.slug}`, date: `${MON[+m]} ${y}` }; });
---
<Site jsonLd={orgLd}>
  <ShaderHero
    client:load
    eyebrow="Mine Developer & Operator · Amlabad, Eastern Jharia"
    title="Reviving underground coal"
    accentWords={1}
    description={SITE.description}
    primary={{ label: 'Explore operations', href: '/operations' }}
    secondary={{ label: 'How coal mining works', href: '/learn' }}
  />
  <LatestTicker items={tickerItems} />
  <Stats client:visible />
  <Lines client:visible />

  <section class="relative bg-background pb-4 pt-2">
    <div class="mx-auto max-w-6xl px-6">
      <div class="relative overflow-hidden rounded-[2rem] border border-white/10 bg-black">
        <video id="heroVideo" class="aspect-video w-full object-cover" autoplay muted loop playsinline preload="metadata"
          poster="https://docs.mangalamcoal.com/media/amlabad-drone-1.jpg" aria-label="Aerial footage of the Amlabad colliery">
          <source src="https://docs.mangalamcoal.com/media/amlabad-drone-1.mp4" type="video/mp4" />
        </video>
        <!-- Logo lock-up: fades in as the drone zooms out at the end of the loop -->
        <div id="heroLogo" class="pointer-events-none absolute inset-0 flex flex-col items-center justify-start pt-[5%] opacity-0"
          style="background:radial-gradient(ellipse 55% 52% at 50% 22%, rgba(0,0,0,0.6), rgba(0,0,0,0) 70%)">
          <img src="/mangalam_mark.png" alt="" width="355" height="340" aria-hidden="true"
            class="w-24 md:w-32 lg:w-36 drop-shadow-[0_2px_18px_rgba(0,0,0,0.9)]" />
          <div class="mt-4 flex flex-col items-center" style="text-shadow:0 2px 14px rgba(0,0,0,0.85)">
            <span class="font-[var(--font-display)] text-2xl font-semibold tracking-[0.34em] text-white md:text-3xl">MANGALAM</span>
            <span class="mt-1.5 text-[10px] font-medium uppercase tracking-[0.42em] text-white/70 md:text-xs">Coalfield</span>
          </div>
        </div>
        <div class="pointer-events-none absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent p-6">
          <p class="text-sm font-medium text-white/90">The Amlabad colliery — Eastern Jharia, Jharkhand</p>
        </div>
      </div>
      <script is:inline>
        (() => {
          const v = document.getElementById('heroVideo');
          const l = document.getElementById('heroLogo');
          if (!v || !l) return;
          // Fade the logo in over the final zoom-out, hold, then fade out just before the loop.
          const onTick = () => {
            const d = v.duration || 24;
            if (!d || isNaN(d)) return;
            const p = v.currentTime / d;
            let o = 0;
            if (p >= 0.54 && p < 0.90) o = (p - 0.54) / 0.36;      // fade in (twice as long, ~last 8s)
            else if (p >= 0.90 && p < 0.96) o = 1;                  // hold
            else if (p >= 0.96) o = Math.max(0, 1 - (p - 0.96) / 0.04); // fade out before loop
            l.style.opacity = o.toFixed(3);
          };
          v.addEventListener('timeupdate', onTick);
        })();
      </script>
    </div>
  </section>

  <ScrollScene client:visible />
  <MagicBento client:visible />
  <Safety client:visible />
  <CTA client:visible />
</Site>
