---
import Site from '../../layouts/Site.astro';
import ShaderHero from '../../components/magic/ShaderHero.tsx';
import circulars from '../../data/circular-index.json';

// "Circular Finder" — search DGMS circulars buried inside the big consolidated
// compilations. Each entry maps a circular to its compilation file + physical
// page (so the #page anchor lands on it). 2018–2024 entries carry a clean
// subject parsed from the compilation's table of contents.
const DOCS_BASE = 'https://docs.mangalamcoal.com/regs';
interface CItem { ref: string; subject?: string; date?: string; compilation_filename: string; page: number; printed_page?: number; set: string; snippet: string }
const items = (circulars as CItem[]).map((c) => ({
  ...c,
  subjectText: c.subject || '',
  displayPage: c.printed_page ?? c.page,
  setLabel: c.set === '2018-2024' ? '2018–2024' : '1995–2017',
}));
const count2017 = items.filter((c) => c.set !== '2018-2024').length;
const count2018 = items.filter((c) => c.set === '2018-2024').length;

const breadcrumbLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://mangalamcoal.com/' },
    { '@type': 'ListItem', position: 2, name: 'Regulations', item: 'https://mangalamcoal.com/regulations' },
    { '@type': 'ListItem', position: 3, name: 'Circular Finder', item: 'https://mangalamcoal.com/regulations/circulars' },
  ],
};
---
<Site
  title="DGMS Circular Finder — 1995–present archive"
  description="Search the DGMS circular archive (1995–present). Find any DGMS circular, notification or G.S.R. reference and jump to the exact compilation and page — with the circular's subject and a direct link."
  jsonLd={breadcrumbLd}
>
  <ShaderHero
    client:load compact
    eyebrow="Regulation desk"
    title="DGMS Circular Finder"
    accentWords={1}
    description="Search hundreds of DGMS circulars, notifications and G.S.R. references (1995–present) that live inside the consolidated compilations — and jump straight to the right file and page."
    primary={{ label: 'Back to the library', href: '/regulations' }}
  />

  <section class="relative bg-background py-16">
    <div class="mx-auto max-w-5xl px-6">
      <div class="mb-6 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <p class="max-w-2xl text-muted-foreground">{items.length} indexed circulars. Type a circular number, year, subject or G.S.R. number — results show the subject and open the compilation at the right page.</p>
        <input id="cfind" type="search" placeholder="e.g. inundation, HEMM, No. 07 of 2020…" class="w-full rounded-xl border border-white/10 bg-white/[0.04] px-4 py-3 text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none md:w-80" aria-label="Search circulars" />
      </div>

      <div id="setchips" class="mb-8 flex flex-wrap gap-2.5">
        <button class="setchip active rounded-full border border-primary bg-primary px-4 py-2 text-[13px] font-semibold text-primary-foreground" data-set="all">All ({items.length})</button>
        <button class="setchip rounded-full border border-white/12 px-4 py-2 text-[13px] font-semibold text-muted-foreground transition-colors hover:border-primary" data-set="2018-2024">2018–2024 ({count2018})</button>
        <button class="setchip rounded-full border border-white/12 px-4 py-2 text-[13px] font-semibold text-muted-foreground transition-colors hover:border-primary" data-set="1995-2017">1995–2017 ({count2017})</button>
      </div>

      <div id="clist" class="flex flex-col gap-3">
        {items.map((c) => (
          <div class="citem rounded-2xl border border-white/10 bg-white/[0.04] p-5 backdrop-blur-sm transition-colors hover:border-primary/30"
            data-text={`${c.ref} ${c.subjectText} ${c.snippet} ${c.setLabel}`.toLowerCase()}
            data-set={c.set === '2018-2024' ? '2018-2024' : '1995-2017'}>
            <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
              <div class="min-w-0">
                <h3 class="font-[var(--font-display)] font-semibold text-foreground">{c.ref}</h3>
                {c.subjectText
                  ? <p class="mt-1 text-[13px] leading-relaxed text-muted-foreground">{c.subjectText}</p>
                  : (c.snippet && <p class="mt-1 line-clamp-2 text-[13px] italic leading-relaxed text-muted-foreground/80">…{c.snippet}…</p>)}
                <p class="mt-2 text-[12px] text-muted-foreground/70">
                  <span class="text-foreground/60">In the</span> {c.setLabel} compilation · <span class="text-foreground/60">page</span> {c.displayPage}
                </p>
              </div>
              <a href={`${DOCS_BASE}/${c.compilation_filename}#page=${c.page}`} target="_blank" rel="noopener noreferrer"
                class="group/open inline-flex shrink-0 items-center gap-1.5 rounded-xl border border-white/15 bg-white/[0.04] px-4 py-2 text-[13px] font-semibold text-foreground transition-colors hover:border-primary hover:text-primary">
                Open
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7M9 7h8v8"/></svg>
              </a>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-8 flex flex-col items-center gap-3">
        <button id="showmore" class="rounded-full border border-white/15 bg-white/[0.04] px-6 py-2.5 text-[13px] font-semibold text-foreground transition-colors hover:border-primary hover:text-primary">Show more</button>
        <p id="cnone" class="hidden text-center text-muted-foreground">No circulars match your search.</p>
        <p id="ccount" class="text-[12px] text-muted-foreground/60"></p>
      </div>
      <p class="mt-8 text-[12px] leading-relaxed text-muted-foreground/70">These circulars are indexed inside the DGMS consolidated compilations; “Open” launches the compilation at the cited page in a new tab. Reproduced from the official DGMS archive for public reference.</p>
    </div>
  </section>

  <script>
    const PAGE = 24;
    const items = Array.from(document.querySelectorAll('#clist .citem')) as HTMLElement[];
    const input = document.getElementById('cfind') as HTMLInputElement;
    const none = document.getElementById('cnone');
    const more = document.getElementById('showmore') as HTMLButtonElement;
    const countEl = document.getElementById('ccount');
    const chips = document.querySelectorAll('#setchips .setchip');
    let activeSet = 'all';
    let shown = PAGE;

    function matches(el: HTMLElement, q: string) {
      const okSet = activeSet === 'all' || el.dataset.set === activeSet;
      const okQ = !q || (el.dataset.text || '').includes(q);
      return okSet && okQ;
    }
    function render() {
      const q = (input?.value || '').trim().toLowerCase();
      const filtered = items.filter((el) => matches(el, q));
      items.forEach((el) => { el.style.display = 'none'; });
      filtered.slice(0, shown).forEach((el) => { el.style.display = ''; });
      none?.classList.toggle('hidden', filtered.length !== 0);
      if (more) more.style.display = filtered.length > shown ? '' : 'none';
      if (countEl) countEl.textContent = filtered.length ? `Showing ${Math.min(shown, filtered.length)} of ${filtered.length}` : '';
    }
    input?.addEventListener('input', () => { shown = PAGE; render(); });
    more?.addEventListener('click', () => { shown += PAGE; render(); });
    chips.forEach((chip) => chip.addEventListener('click', () => {
      chips.forEach((c) => { c.classList.remove('active', 'bg-primary', 'text-primary-foreground', 'border-primary'); c.classList.add('text-muted-foreground', 'border-white/12'); });
      chip.classList.add('active', 'bg-primary', 'text-primary-foreground', 'border-primary'); chip.classList.remove('text-muted-foreground', 'border-white/12');
      activeSet = (chip as HTMLElement).dataset.set || 'all'; shown = PAGE; render();
    }));
    render();
  </script>
</Site>
