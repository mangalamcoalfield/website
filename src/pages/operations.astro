---
import Site from '../layouts/Site.astro';
import ShaderHero from '../components/magic/ShaderHero.tsx';
import PitMap from '../components/magic/PitMap.tsx';
import MagicBento from '../components/magic/MagicBento.tsx';
import { Lines } from '../components/magic/MagicSections.tsx';
---
<Site title="Operations & Capabilities" description="Mangalam's two commercial lines — underground coal across all four Amlabad pits, and coal bed methane — run under one operator in the Eastern Jharia Area, Bokaro.">
  <ShaderHero
    client:load
    compact
    eyebrow="Operations & capabilities"
    title="Two operations, one operator"
    accentWords={2}
    description="Through the Amlabad block in the Eastern Jharia Area of District Bokaro, Jharkhand, Mangalam runs two commercial lines — underground coal across all four pits, and the coal bed methane held within the same seams — all under one operator."
    primary={{ label: 'Safety & compliance', href: '/safety' }}
  />

  <section class="relative bg-background py-16">
    <div class="mx-auto max-w-6xl px-6">
      <div class="max-w-3xl">
        <span class="text-[11px] font-semibold uppercase tracking-[0.28em] text-primary">How the coal is mined</span>
        <h2 class="mt-3 font-[var(--font-display)] text-4xl font-bold tracking-tight text-foreground md:text-5xl">Prime coking coal, won underground.</h2>
        <p class="mt-4 text-[17px] leading-8 text-muted-foreground">The Amlabad block lies in the Jharia Coalfield — India's principal source of prime coking coal — within the Gondwana Barakar coal measures of the Damodar Valley. The coal is won underground by the bord-and-pillar method, and seam for seam it is prized washery-grade coking coal, the raw material of steel-making. The same seams hold coal bed methane; capturing it improves safety underground and adds a second energy stream. Every part of the work runs to the statutory rulebook — the Mines Act, the Coal Mines Regulations 2017 and DGMS oversight.</p>
      </div>
      <div class="mt-10 overflow-hidden rounded-3xl border border-white/10">
        <img src="/images/amlabad-headframe.jpg" alt="Pit headframe at the Amlabad colliery, Eastern Jharia Area, Bokaro" class="aspect-[16/9] w-full object-cover" loading="lazy" width="2000" height="1500" />
      </div>

      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <a href="/learn/bord-and-pillar-mining" class="group rounded-2xl border border-white/10 bg-white/[0.04] p-6 transition-all hover:-translate-y-1 hover:border-primary/30">
          <div class="font-[var(--font-display)] text-lg font-semibold text-foreground">Bord &amp; pillar</div>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">How underground coal is won in galleries and pillars — and the ground kept stable.</p>
          <span class="mt-3 inline-block text-[13px] font-semibold text-primary">How it works →</span>
        </a>
        <a href="/learn/coking-coal-and-coal-grades" class="group rounded-2xl border border-white/10 bg-white/[0.04] p-6 transition-all hover:-translate-y-1 hover:border-primary/30">
          <div class="font-[var(--font-display)] text-lg font-semibold text-foreground">Prime coking coal</div>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">Washery grades W-I and W-II, and why prime coking coal is the raw material of steel.</p>
          <span class="mt-3 inline-block text-[13px] font-semibold text-primary">Coal &amp; grades →</span>
        </a>
        <a href="/learn/coal-bed-methane-explained" class="group rounded-2xl border border-white/10 bg-white/[0.04] p-6 transition-all hover:-translate-y-1 hover:border-primary/30">
          <div class="font-[var(--font-display)] text-lg font-semibold text-foreground">Coal bed methane</div>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">The gas held in the seams — a safety measure and a second energy stream.</p>
          <span class="mt-3 inline-block text-[13px] font-semibold text-primary">The science →</span>
        </a>
        <a href="/learn/dgms-and-the-rules-of-the-mine" class="group rounded-2xl border border-white/10 bg-white/[0.04] p-6 transition-all hover:-translate-y-1 hover:border-primary/30">
          <div class="font-[var(--font-display)] text-lg font-semibold text-foreground">Run to the rulebook</div>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">The Mines Act, CMR 2017 and DGMS — the statutory framework every mine works under.</p>
          <span class="mt-3 inline-block text-[13px] font-semibold text-primary">The framework →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- The revival, step by step -->
  <section class="relative bg-background py-20">
    <div class="mx-auto max-w-3xl px-6">
      <div class="mb-12 max-w-2xl">
        <span class="text-[11px] font-semibold uppercase tracking-[0.28em] text-primary">The revival, step by step</span>
        <h2 class="mt-3 font-[var(--font-display)] text-4xl font-bold tracking-tight text-foreground md:text-5xl">Bringing Amlabad back.</h2>
        <p class="mt-4 leading-relaxed text-muted-foreground">A colliery that ran for a century, fell silent, and is now being returned to production under a modern operating model.</p>
      </div>
      <ol class="relative ml-2 space-y-9 border-l border-white/12 pl-8">
        {[
          { k: 'A century of mining', b: 'Amlabad began winning coal from the Jharia Coalfield more than a hundred years ago. Its pit headframes are among the oldest working landmarks in the Eastern Jharia Area, Bokaro — and its seams among India’s finest prime coking coal.' },
          { k: '2008 · Operations halted', b: 'After the guide rope of the No. 2 pit’s chute gave way, the colliery was stopped on safety grounds. It would stay shut for the better part of two decades.' },
          { k: 'A prime resource left idle', b: 'For years the seams sat unworked while India imported the very grade of coking coal they hold — the raw material its steel plants depend on.' },
          { k: 'Revival through an MDO', b: 'BCCL moved to bring the mine back through the mine developer & operator (MDO) model on a revenue-sharing basis, engaging Mangalam Coalfield Private Limited as the operator.' },
          { k: 'Formalities completed, restart directed', b: 'With the approvals and agreements in place, BCCL’s leadership directed the restart of Amlabad in MDO mode, targeting a return to production.' },
          { k: 'A 25-year horizon', b: 'Reopened, Amlabad is set to supply prime coking coal for around two decades — import substitution for steel and energy security — with coal bed methane from the same seams as a second, cleaner stream.' },
          { k: 'February 2026 · Beyond coal', b: 'On the founder’s 60th birth anniversary, the Mangalam Chikitsalaya opened at the colliery — free treatment for the workforce and the villages around it.' },
        ].map((s) => (
          <li class="relative">
            <span class="absolute -left-[41px] top-1.5 grid h-4 w-4 place-items-center rounded-full border-2 border-primary bg-background"><span class="h-1.5 w-1.5 rounded-full bg-primary"></span></span>
            <h3 class="font-[var(--font-display)] text-lg font-semibold text-foreground">{s.k}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{s.b}</p>
          </li>
        ))}
      </ol>
      <p class="mt-10 text-[12px] leading-relaxed text-muted-foreground/60">Timeline compiled from public press coverage of the Amlabad revival; see <a href="/news" class="text-primary hover:underline">In the news</a>. Specific production figures and internal plans are not published here.</p>
    </div>
  </section>

  <Lines client:visible />
  <PitMap client:visible />
  <MagicBento client:visible />
</Site>
