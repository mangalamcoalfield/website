---
import Site from '../layouts/Site.astro';
import ShaderHero from '../components/magic/ShaderHero.tsx';
import ApplicationForm from '../components/ApplicationForm.astro';
import { safeSelect, type Job } from '../lib/supabase';
import { placeholderJobs } from '../data/placeholders';
import { SITE } from '../data/site';

// Data-driven from `jobs` (status='published'); fallback to placeholders.
let jobs = await safeSelect<Job>((c) =>
  c.from('jobs').select('*').eq('status', 'published').order('posted_at', { ascending: false })
);
const usingPlaceholders = jobs.length === 0;
if (usingPlaceholders) jobs = placeholderJobs;

const empType = (t: string | null) =>
  /part/i.test(t || '') ? 'PART_TIME' : /contract/i.test(t || '') ? 'CONTRACTOR' : 'FULL_TIME';

const jobLd = jobs.map((j) => ({
  '@context': 'https://schema.org',
  '@type': 'JobPosting',
  title: j.title,
  description: j.description || j.title,
  datePosted: j.posted_at || undefined,
  employmentType: empType(j.type),
  hiringOrganization: { '@type': 'Organization', name: SITE.legalName, sameAs: 'https://mangalamcoal.com', logo: 'https://mangalamcoal.com/mangalam_logo.png' },
  jobLocation: { '@type': 'Place', address: { '@type': 'PostalAddress', streetAddress: j.location || 'Amlabad, Eastern Jharia', addressLocality: 'Amlabad, Eastern Jharia', addressRegion: 'Jharkhand', addressCountry: 'IN' } },
  ...(j.dept ? { occupationalCategory: j.dept } : {}),
  directApply: true,
}));
---
<Site title="Careers" description="Open roles at Mangalam Coalfield — mining engineers, statutory safety, electrical and mechanical positions. Apply directly with your résumé." jsonLd={jobLd}>
  <ShaderHero
    client:load compact
    eyebrow="Careers"
    title="Build a career in Indian coal mining"
    accentWords={3}
    description="From mining engineers to electrical and statutory roles — join a company that runs its operations to standard."
    primary={{ label: 'See open roles', href: '#roles' }}
  />

  <section id="roles" class="relative bg-background py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-10 max-w-2xl">
        <span class="text-[11px] font-semibold uppercase tracking-[0.28em] text-primary">Open roles</span>
        <h2 class="mt-3 font-[var(--font-display)] text-4xl font-bold tracking-tight text-foreground md:text-5xl">Current openings.</h2>
        <p class="mt-4 text-muted-foreground">All roles are based at the Amlabad block in Eastern Jharia, Jharkhand unless stated otherwise.</p>
      </div>
      <div class="flex flex-col gap-4">
        {jobs.map((j) => (
          <div class="flex flex-col items-start justify-between gap-4 rounded-2xl border border-white/10 bg-white/[0.04] p-7 backdrop-blur-sm transition-colors hover:border-primary/30 sm:flex-row sm:items-center">
            <div>
              <h3 class="font-[var(--font-display)] text-xl font-semibold text-foreground">{j.title}</h3>
              <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1 text-[13px] text-muted-foreground">
                {j.dept && <span>{j.dept}</span>}
                {j.location && <span>{j.location}</span>}
                {j.type && <span>{j.type}</span>}
              </div>
              {j.description && <p class="mt-3 max-w-2xl text-sm text-muted-foreground">{j.description}</p>}
            </div>
            <a href="#apply" class="shrink-0 rounded-xl border border-white/15 bg-white/[0.04] px-5 py-2.5 text-[13px] font-semibold text-foreground transition-colors hover:border-primary hover:text-primary">Apply</a>
          </div>
        ))}
      </div>
      {usingPlaceholders && (
        <p class="mt-8 text-sm text-muted-foreground">Placeholder roles shown. Live openings are published from the careers pipeline.</p>
      )}
    </div>
  </section>

  <section id="apply" class="relative bg-background pb-28">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-10 max-w-2xl">
        <span class="text-[11px] font-semibold uppercase tracking-[0.28em] text-primary">Apply</span>
        <h2 class="mt-3 font-[var(--font-display)] text-4xl font-bold tracking-tight text-foreground md:text-5xl">Submit your application.</h2>
        <p class="mt-4 text-muted-foreground">Tell us who you are, choose a role, and attach your résumé. We review every application.</p>
      </div>
      <div class="rounded-3xl border border-white/10 bg-white/[0.02] p-8 backdrop-blur-sm">
        <ApplicationForm jobs={jobs} />
      </div>
    </div>
  </section>
</Site>
