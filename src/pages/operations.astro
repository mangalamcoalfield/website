---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';

// All four Amlabad pits. Statuses are general revival/development stages — no
// production schedules, reserves or mine-plan economics (publish-filter).
const pits = [
  { no: 'Pit No. 1', status: 'Revival', desc: 'Historic underground working under revival as part of the Amlabad block restoration.' },
  { no: 'Pit No. 2', status: 'Development', desc: 'Underground development to open up access and working districts.' },
  { no: 'Pit No. 3', status: 'Development', desc: 'Development of roadways and galleries through the coal seam.' },
  { no: 'Pit No. 4', status: 'Dewatering', desc: 'Dewatering and rehabilitation ahead of further development.' },
];
---
<Base title="Operations & Capabilities" description="Mangalam's two commercial lines — underground coal across all four Amlabad pits, and coal bed methane — plus our core mining capabilities.">
  <PageHero
    eyebrow="Operations & capabilities"
    title="Two operations, one operator."
    underline="one operator."
    lead="Through the Amlabad block in Eastern Jharia, Jharkhand, Mangalam runs two commercial lines — underground coal across all four pits, and the coal bed methane held within the same seams."
  />

  <!-- Two business lines -->
  <section class="block on-light">
    <div class="wrap">
      <div class="lines reveal">
        <div class="line">
          <span class="tag">01</span>
          <div class="lab"><b>Coal</b> · Mining</div>
          <h3>Reviving the Amlabad pits</h3>
          <p>Restoring the historic underground workings of the Amlabad block — Pit No. 1, 2, 3 and 4 — across revival, development and dewatering. Our positioning is simple: powering India's industrial growth through responsible coal.</p>
        </div>
        <div class="line">
          <span class="tag">02</span>
          <div class="lab"><b>Coal Bed</b> · Methane</div>
          <h3>Energy within the seam</h3>
          <p>Commercially capturing the methane held inside the coal seams — a cleaner energy stream from the same block, put to use rather than vented to the atmosphere. A new commercial vertical alongside coal.</p>
        </div>
      </div>

      <p class="subhead reveal">The four Amlabad pits · Eastern Jharia, Jharkhand</p>
      <div class="pits stagger reveal">
        {pits.map((p) => (
          <div class="pit">
            <div class="no">{p.no}</div>
            <span class="status">{p.status}</span>
            <h3>{p.no}</h3>
            <p>{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Capabilities -->
  <section class="block on-forest">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow">Capabilities</span>
        <h2>How we operate.</h2>
        <p class="lead">Four core capabilities run every working district to standard.</p>
      </div>
      <div class="cards stagger reveal">
        <div class="card"><span class="ix">01</span><h3>Mine Development</h3><p>Driving and supporting underground roadways and galleries that open up the coal seam for production.</p></div>
        <div class="card"><span class="ix">02</span><h3>Underground Operations</h3><p>Shift-by-shift production, reconciliation, and structured reporting across every working district.</p></div>
        <div class="card"><span class="ix">03</span><h3>Electrical &amp; Mechanical</h3><p>Maintaining DGMS-approved equipment and statutory testing that keep machinery safe and certified.</p></div>
        <div class="card"><span class="ix">04</span><h3>Statutory Compliance</h3><p>Operating to the Coal Mines Regulations 2017 and the Mines Act 1952, with qualified officials in every position.</p></div>
      </div>
      <div class="reveal" style="margin-top:48px">
        <a class="tlink" href="/safety">Safety &amp; compliance approach <svg width="18" height="18"><use href="#arrow"/></svg></a>
      </div>
    </div>
  </section>
</Base>
