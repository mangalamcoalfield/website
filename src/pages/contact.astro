---
import Site from '../layouts/Site.astro';
import ShaderHero from '../components/magic/ShaderHero.tsx';
import ContactForm from '../components/ContactForm.astro';
import { SITE } from '../data/site';
---
<Site title="Contact" description="Get in touch with Mangalam Coalfield Private Limited — enquiries, partnerships, and general contact.">
  <ShaderHero
    client:load compact
    eyebrow="Contact"
    title="Get in touch"
    accentWords={1}
    description="For enquiries, partnerships or general questions, send us a message and we will be in touch."
  />

  <section class="relative bg-background pb-28 pt-4">
    <div class="mx-auto grid max-w-6xl gap-12 px-6 lg:grid-cols-[1.15fr_.85fr]">
      <div>
        <span class="text-[11px] font-semibold uppercase tracking-[0.28em] text-primary">Send a message</span>
        <h2 class="mb-8 mt-3 font-[var(--font-display)] text-3xl font-bold tracking-tight text-foreground md:text-4xl">We read every enquiry.</h2>
        <ContactForm />
      </div>
      <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-8 backdrop-blur-sm">
        <span class="text-[11px] font-semibold uppercase tracking-[0.28em] text-primary">Reach us</span>
        <dl class="mt-6 flex flex-col gap-6">
          <div>
            <dt class="font-[var(--font-display)] text-sm font-semibold text-foreground">Operations</dt>
            <dd class="mt-1 text-muted-foreground">{SITE.location}</dd>
          </div>
          <div>
            <dt class="font-[var(--font-display)] text-sm font-semibold text-foreground">Registered office</dt>
            <dd class="mt-1 text-muted-foreground">{SITE.regOffice.replace('Registered office · ', '')}</dd>
          </div>
          <div>
            <dt class="font-[var(--font-display)] text-sm font-semibold text-foreground">Email</dt>
            <dd class="mt-1"><a href={`mailto:${SITE.hrEmail}`} class="text-primary hover:underline">{SITE.hrEmail}</a></dd>
          </div>
          <div>
            <dt class="font-[var(--font-display)] text-sm font-semibold text-foreground">Employees</dt>
            <dd class="mt-1"><a href={SITE.portalUrl} rel="noopener" class="inline-flex items-center gap-1 text-primary hover:underline">Employee Portal<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7M9 7h8v8"/></svg></a></dd>
          </div>
        </dl>
      </div>
    </div>
  </section>
</Site>
