---
import Site from '../layouts/Site.astro';
import { SITE } from '../data/site';
---
<Site title="Employee Mail" description="Sign in to your @mangalamcoal.com mailbox — the Mangalam Coalfield employee webmail gateway.">
  <section class="relative flex min-h-[72vh] items-center justify-center bg-background px-6 py-24">
    <div class="w-full max-w-md rounded-3xl border border-white/10 bg-white/[0.03] p-9 text-center backdrop-blur-sm">
      <div class="mx-auto mb-6 flex size-14 items-center justify-center rounded-2xl border border-primary/20 bg-primary/[0.08]">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
      </div>
      <span class="text-[11px] font-semibold uppercase tracking-[0.28em] text-primary">Employee Mail</span>
      <h1 class="mt-3 font-[var(--font-display)] text-3xl font-bold text-foreground">Mangalam webmail</h1>
      <p class="mt-3 leading-relaxed text-muted-foreground">Sign in to your <strong class="text-foreground/80">@mangalamcoal.com</strong> mailbox. Your email is hosted securely on Hostinger — continue to the login below.</p>
      <a href={SITE.webmailUrl} rel="noopener"
        class="mt-7 inline-flex w-full items-center justify-center gap-2 rounded-full bg-primary px-6 py-3.5 text-sm font-semibold text-primary-foreground shadow-[0_0_45px_-8px_hsl(var(--primary)/0.7)] transition-transform hover:scale-[1.02]">
        Log in to Employee Mail
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h13M13 6l6 6-6 6"/></svg>
      </a>
      <p class="mt-4 text-[12px] leading-relaxed text-muted-foreground/60">For your security, you'll enter your password on the Hostinger mail server itself — never on this site.</p>
    </div>
  </section>
</Site>
