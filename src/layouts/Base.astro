---
// Self-hosted fonts via Fontsource (no CDN). Weights match the draft:
// Archivo 500/600/700 (display), Hanken Grotesk 400/500/600 (body).
import '@fontsource/archivo/500.css';
import '@fontsource/archivo/600.css';
import '@fontsource/archivo/700.css';
import '@fontsource/hanken-grotesk/400.css';
import '@fontsource/hanken-grotesk/500.css';
import '@fontsource/hanken-grotesk/600.css';
import '../styles/global.css';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Icons from '../components/Icons.astro';
import AskMangalam from '../components/AskMangalam.astro';
import { SITE } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  /** Optional JSON-LD object(s) injected into <head> as application/ld+json. */
  jsonLd?: object | object[];
}

const { title, description = SITE.description, jsonLd } = Astro.props;
const fullTitle = title ? `${title} · ${SITE.name}` : `${SITE.name} — Mine Developer & Operator`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).href;
const ldArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/png" href="/mangalam_logo.png" />
  <meta name="theme-color" content="#000000" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={SITE.name} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content="/mangalam_logo.png" />
  <meta name="twitter:card" content="summary" />

  {ldArray.map((obj) => (
    <script type="application/ld+json" set:html={JSON.stringify(obj)} />
  ))}
</head>
<body>
  <Icons />
  <Header />
  <main id="main">
    <slot />
  </main>
  <Footer />
  <AskMangalam />

  <script>
    // Calm fade-up reveals via IntersectionObserver (respects reduced-motion
    // through the CSS media query, which neutralises the .reveal transforms).
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('in');
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.16 }
    );
    document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
  </script>
</body>
</html>
