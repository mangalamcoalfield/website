---
// /magic-preview — Magic (21st.dev) × UI-UX Pro Max showcase. Green/lime brand
// on coal-black, with interactive graphics & fluid motion: a canvas particle
// constellation hero, cursor spotlight, drifting mesh glow, marquee ticker,
// animated count-ups, 3D-tilt cards, animated bento, dramatic safety, glow CTA.
import '@fontsource/archivo/600.css';
import '@fontsource/archivo/700.css';
import '@fontsource/hanken-grotesk/400.css';
import '@fontsource/hanken-grotesk/500.css';
import '@fontsource/hanken-grotesk/600.css';
import '../styles/magic.css';
import ParticleHero from '../components/magic/ParticleHero.tsx';
import MagicBento from '../components/magic/MagicBento.tsx';
import { Marquee, Stats, Lines, Safety, CTA } from '../components/magic/MagicSections.tsx';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Magic × Pro Max showcase · Mangalam Coalfield</title>
  <meta name="robots" content="noindex" />
  <style>
    html,body{margin:0;background:#06100b;font-family:'Hanken Grotesk',system-ui,sans-serif}
    .mp-badge{position:fixed;top:14px;left:50%;transform:translateX(-50%);z-index:50;font-size:11.5px;font-weight:700;
      color:#10130d;background:linear-gradient(180deg,#d6e98a,#aecf3e);padding:6px 14px;border-radius:20px;box-shadow:0 8px 28px rgba(174,207,62,.3)}
    .mp-badge a{color:#10130d;text-decoration:underline}
  </style>
</head>
<body>
  <div class="mp-badge">⚡ 21st.dev Magic × UI-UX Pro Max · <a href="/">live site</a></div>

  <ParticleHero
    client:load
    eyebrow="Mine Developer & Operator · Amlabad, Eastern Jharia"
    title="Reviving underground coal"
    accentWords={1}
    description="Mangalam Coalfield is reviving the historic Amlabad pits in Eastern Jharia — producing coal and the coal bed methane held within the same seams, with safety and statutory rigour on every shift."
    primary={{ label: 'Explore operations', href: '#caps' }}
    secondary={{ label: 'View the live site', href: '/' }}
  />

  <Marquee client:visible />
  <Stats client:visible />
  <Lines client:visible />
  <div id="caps"><MagicBento client:visible /></div>
  <Safety client:visible />
  <CTA client:visible />
</body>
</html>
