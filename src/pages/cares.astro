---
import Site from '../layouts/Site.astro';
import ShaderHero from '../components/magic/ShaderHero.tsx';
import { safeSelect, type CsrProject } from '../lib/supabase';
import { placeholderCsr } from '../data/placeholders';

let projects = await safeSelect<CsrProject>((c) =>
  c.from('csr_projects').select('*').eq('published', true).order('date', { ascending: false })
);
const usingPlaceholder = projects.length === 0;
if (usingPlaceholder) projects = placeholderCsr;

const pillLabel = (s: string) => (s === 'completed' ? 'Completed' : s === 'ongoing' ? 'Ongoing' : 'Planned');
const pillClasses = (s: string) =>
  s === 'completed' ? 'bg-primary/15 text-primary' : 'bg-secondary/20 text-[#9ed3c4]';

// Community work as covered by the local press / photographed on the day.
const COM = 'https://docs.mangalamcoal.com/media/community';
const community = [
  { img: `${COM}/community-blackdiamond-2026.jpg`, title: 'Black Diamond Awards begin', date: 'Apr 2026', cap: 'A recognition scheme for the workforce opens at Amlabad. Its first “emergency warriors” — Sukhdev, Bharat and Suraj Rajwar — were honoured for clearing a machine breakdown underground in thirty minutes.' },
  { img: `${COM}/community-ramkrishna-2026.jpg`, title: 'Ramakrishna Paramahamsa jayanti', date: 'Feb 2026', cap: 'The 191st birth anniversary observed at the Ramakrishna Vivekananda Sevashram, Yogideeh, with Mangalam taking part and clothes given to families in need.' },
  { img: `${COM}/community-chikitsalaya-2026.jpg`, title: 'The Chikitsalaya opens', date: 'Feb 2026', cap: 'The Mangalam Chikitsalaya inaugurated at the colliery on the founder’s 60th birth anniversary, alongside a free health camp: more than 250 patients screened and 34 blood donors — his wife, Smt. Urmil Agarwal, among them.' },
  { img: `${COM}/community-plaque-2026.jpg`, title: 'The dedication', date: '18 Feb 2026', cap: 'The plaque at the hospital door — opened in the sacred memory of Late Shri Shree Gopal Agarwal, on his birth anniversary, by the hands of his wife, Smt. Urmil Agarwal.' },
  { img: `${COM}/community-blankets-2025.jpg`, title: 'Blankets for the winter', date: 'Dec 2025', cap: 'Around 250 people given blankets at the Yogideeh ashram, with a warm meal served to some 500.' },
  { img: `${COM}/community-plantation-2025.jpg`, title: 'Plantation & environment drive', date: 'Sep 2025', cap: 'Dozens of saplings planted at the Amlabad colliery on an environment-awareness day.' },
  { img: `${COM}/community-vastra-2024.jpg`, title: 'Clothes for families in need', date: 'Oct 2024', cap: 'Garments distributed to families at the Ramakrishna Vivekananda Sevashram, Yogideeh, during Durga Puja.' },
  { img: `${COM}/community-durgapuja-2024.jpg`, title: 'Durga Puja at the colliery', date: 'Oct 2024', cap: 'Mangalam hosts the community Durga Puja at Amlabad — a gathering for the workforce and surrounding villages.' },
];
---
<Site title="Mangalam Cares" description="Mangalam's CSR and environmental sustainability work around the Amlabad mine — community welfare, skills and safety training, and land care. Completed work shown with evidence; planned work clearly labelled.">
  <ShaderHero
    client:load compact
    eyebrow="Mangalam Cares"
    title="The work above ground matters too"
    accentWords={2}
    description="Beyond production, Mangalam invests in the people and the environment around the mine. We showcase our own contributions: completed work with evidence, and planned work clearly labelled."
  />

  <section class="relative bg-background pt-14">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid items-center gap-10 lg:grid-cols-2">
        <div>
          <span class="text-[11px] font-semibold uppercase tracking-[0.28em] text-primary">The founder's wish</span>
          <h2 class="mt-3 font-[var(--font-display)] text-3xl font-bold leading-tight tracking-tight text-foreground md:text-4xl">“Let Amlabad yield not only coal, but prosperous lives.”</h2>
          <p class="mt-5 leading-relaxed text-muted-foreground">That was the wish of our founder, Late Shri Shree Gopal Agarwal. On what would have been his 60th birth anniversary, his wife, Smt. Urmil Agarwal, inaugurated the <strong class="text-foreground/80">Mangalam Chikitsalaya</strong> at Amlabad — a hospital where treatment is free for our workforce and the villages around the colliery.</p>
          <p class="mt-4 leading-relaxed text-muted-foreground">The work below carries that wish forward.</p>
        </div>
        <div class="overflow-hidden rounded-3xl border border-white/10">
          <img src="/images/mangalam-chikitsalaya.jpg" alt="The Mangalam Chikitsalaya at Amlabad Colliery on its inauguration day" class="aspect-[3/2] w-full object-cover" loading="lazy" width="1600" height="1066" />
        </div>
      </div>
    </div>
  </section>

  <section class="relative bg-background py-20">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="mb-8 font-[var(--font-display)] text-2xl font-bold tracking-tight text-foreground md:text-3xl">Our work</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {projects.map((p) => (
          <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-7 backdrop-blur-sm transition-all hover:-translate-y-1 hover:border-primary/30">
            <span class={`inline-block rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-wide ${pillClasses(p.status)}`}>{pillLabel(p.status)}</span>
            <h3 class="mt-4 font-[var(--font-display)] text-lg font-semibold text-foreground">{p.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{p.description}</p>
            {p.impact_numbers && <p class="mt-3 text-sm font-semibold text-primary">{p.impact_numbers}</p>}
            {p.evidence_url && (
              <a href={p.evidence_url} rel="noopener" class="mt-4 inline-flex items-center gap-1.5 text-[13px] font-semibold text-primary hover:underline">View evidence →</a>
            )}
          </div>
        ))}
      </div>
      {usingPlaceholder && (
        <p class="mt-8 text-sm text-muted-foreground">Placeholder programmes shown. Real CSR write-ups — with evidence for completed work — will be published from the content track.</p>
      )}
    </div>
  </section>

  <!-- In the community, as reported -->
  <section class="relative bg-background pb-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-8 max-w-2xl">
        <span class="text-[11px] font-semibold uppercase tracking-[0.28em] text-primary">In the community</span>
        <h2 class="mt-3 font-[var(--font-display)] text-2xl font-bold tracking-tight text-foreground md:text-3xl">On the ground, as reported.</h2>
        <p class="mt-3 leading-relaxed text-muted-foreground">Moments from the work around Amlabad — festivals, relief and environment drives — as photographed on the day and covered by the local press.</p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {community.map((c) => (
          <a href={c.img} target="_blank" rel="noopener noreferrer"
            class="group flex flex-col overflow-hidden rounded-2xl border border-white/10 bg-white/[0.04] transition-all hover:-translate-y-1 hover:border-primary/30">
            <div class="flex h-52 items-center justify-center bg-neutral-100 p-2">
              <img src={c.img} alt={c.cap} loading="lazy" class="max-h-full w-auto object-contain" />
            </div>
            <div class="p-5">
              <div class="flex items-center gap-x-2 text-[12px] text-muted-foreground/80">
                <span class="font-semibold text-primary">{c.title}</span><span>· {c.date}</span>
              </div>
              <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{c.cap}</p>
            </div>
          </a>
        ))}
      </div>
      <p class="mt-8 text-[12px] leading-relaxed text-muted-foreground/70">Press clippings shown for reference; copyright remains with the respective publishers.</p>
    </div>
  </section>
</Site>
