---
import Site from '../../layouts/Site.astro';
import ShaderHero from '../../components/magic/ShaderHero.tsx';
import { safeSelect, type Regulation } from '../../lib/supabase';
import draftWatch from '../../data/draft-watch.json';

// Data-driven from `regulations` (published only). Files hosted externally;
// download_url filled after upload. Placeholder fallback keeps the build green.
let regs = await safeSelect<Regulation>((c) =>
  c.from('regulations').select('*').eq('published', true).order('sort_order', { ascending: true })
);
const usingPlaceholder = regs.length === 0;
if (usingPlaceholder) regs = [
  { id: 'ph1', slug: 'coal-mines-regulations-2017', title: 'Coal Mines Regulations, 2017', category: 'cmr_2017', summary: 'The principal safety regulations governing coal mines in India under the Mines Act 1952.', doc_number: null, authority: 'DGMS', issued_date: '2017', status: 'in_force', status_note: null, source_url: 'https://www.dgms.gov.in', download_url: null, file_size_kb: null, tags: [], relevance: 1, sort_order: 10 },
] as Regulation[];

const CAT: Record<string, string> = {
  cmr_2017: 'Coal Mines Regulations', mines_act: 'Mines Act & Rules', dgms_circular: 'DGMS Circulars',
  dgms_notification: 'DGMS Notifications', labour_code: 'Labour Codes', mmdr: 'MMDR & Mineral Concession',
  env_forest: 'Environment & Forest', moc: 'Ministry of Coal Guidelines', cea: 'Electrical (CEA)', draft: 'Drafts & Consultations',
};
const order = ['cmr_2017', 'mines_act', 'dgms_circular', 'dgms_notification', 'mmdr', 'env_forest', 'labour_code', 'cea', 'moc', 'draft'];
const cats = order.filter((c) => regs.some((r) => r.category === c));
const statusBadge = (s: string) => s === 'draft' ? 'bg-secondary/20 text-[#9ed3c4]' : s === 'superseded' ? 'bg-white/10 text-muted-foreground' : 'bg-primary/15 text-primary';
const statusLabel = (s: string) => s === 'in_force' ? 'In force' : s === 'superseded' ? 'Superseded' : s === 'draft' ? 'Draft' : s;
// Cornerstone instruments shown as cards; the rest go into the compact list.
const FEAT_ORDER = ['cmr_2017', 'mines_act', 'labour_code', 'mmdr', 'env_forest', 'dgms_circular', 'draft', 'dgms_notification', 'cea', 'moc'];
const featured = regs.filter((r) => r.featured).sort((a, b) => FEAT_ORDER.indexOf(a.category) - FEAT_ORDER.indexOf(b.category));

// Tracker 1 — "Latest from DGMS": most recent dated circulars/notifications.
const MON = ['', 'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
const fmtD = (d: string) => { const [y, m, dd] = d.slice(0, 10).split('-'); return `${+dd} ${MON[+m]} ${y}`; };
const latestDgms = regs
  .filter((r) => (r.category === 'dgms_circular' || r.category === 'dgms_notification') && !!r.issued_date && /^\d{4}-\d{2}-\d{2}/.test(r.issued_date))
  .sort((a, b) => (a.issued_date! < b.issued_date! ? 1 : -1))
  .slice(0, 6);
// Tracker 2 — "Draft-Watch": curated pending/changing instruments.
const dwBadge = (s: string) => s === 'Draft' ? 'bg-secondary/20 text-[#9ed3c4]' : s === 'Pending' || s === 'In transition' ? 'bg-[#e0b86a]/15 text-[#e0b86a]' : 'bg-primary/15 text-primary';

const collectionLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Indian Coal-Mining Regulations — Library',
  description: 'A curated, searchable library of Indian coal-mining regulations, circulars and codes with plain-language summaries, official sources and downloads.',
  url: 'https://mangalamcoal.com/regulations',
  isPartOf: { '@type': 'WebSite', name: 'Mangalam Coalfield', url: 'https://mangalamcoal.com' },
  about: cats.map((c) => ({ '@type': 'Thing', name: CAT[c] })),
};
const breadcrumbLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://mangalamcoal.com/' },
    { '@type': 'ListItem', position: 2, name: 'Regulations', item: 'https://mangalamcoal.com/regulations' },
  ],
};
---
<Site
  title="Indian Coal-Mining Regulations — Library"
  description="A free, searchable library of Indian coal-mining regulations — Coal Mines Regulations 2017, the Mines Act, DGMS circulars, labour codes, MMDR & environment rules — with plain-language summaries, official sources and downloads."
  jsonLd={[collectionLd, breadcrumbLd]}
>
  <ShaderHero
    client:load compact
    eyebrow="Regulation desk"
    title="Indian coal-mining regulations, in one place"
    accentWords={2}
    description="A free, curated library of the regulations, circulars and codes that govern Indian coal mining — each with a plain-language summary, the official source, and a download. Built to help the industry, not to sell."
    primary={{ label: 'Browse the library', href: '#library' }}
  />

  <section class="relative bg-background pt-14 pb-2">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-6 lg:grid-cols-2">
        <div class="rounded-3xl border border-white/10 bg-white/[0.03] p-7 backdrop-blur-sm">
          <div class="flex items-center justify-between">
            <span class="text-[11px] font-semibold uppercase tracking-[0.28em] text-primary">Latest from DGMS</span>
            <span class="relative flex h-2 w-2" title="Live from the library"><span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-primary/60"></span><span class="relative inline-flex h-2 w-2 rounded-full bg-primary"></span></span>
          </div>
          <p class="mt-1.5 text-sm text-muted-foreground">The newest circulars &amp; notifications in the library.</p>
          {latestDgms.length > 0 ? (
            <ul class="mt-4 flex flex-col divide-y divide-white/5">
              {latestDgms.map((r) => (
                <li>
                  <a href={`/regulations/${r.slug}`} class="group flex items-start gap-3 py-3">
                    <span class="mt-0.5 shrink-0 rounded-md bg-primary/10 px-2 py-0.5 text-[11px] font-semibold text-primary">{fmtD(r.issued_date!)}</span>
                    <span class="line-clamp-2 text-sm text-foreground/90 transition-colors group-hover:text-primary">{r.title}</span>
                  </a>
                </li>
              ))}
            </ul>
          ) : (<p class="mt-4 text-sm text-muted-foreground">Circulars are being catalogued.</p>)}
        </div>
        <div class="rounded-3xl border border-white/10 bg-white/[0.03] p-7 backdrop-blur-sm">
          <span class="text-[11px] font-semibold uppercase tracking-[0.28em] text-primary">Draft-watch</span>
          <p class="mt-1.5 text-sm text-muted-foreground">What's changing — drafts, roll-outs and pending settlements.</p>
          <ul class="mt-4 flex flex-col gap-3">
            {draftWatch.map((d) => (
              <li class="rounded-xl border border-white/[0.08] bg-white/[0.02] p-4">
                <div class="flex items-start justify-between gap-3">
                  <div class="font-[var(--font-display)] text-[15px] font-semibold text-foreground">{d.href ? <a href={d.href} class="transition-colors hover:text-primary">{d.title}</a> : d.title}</div>
                  <span class={`shrink-0 rounded-full px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide ${dwBadge(d.status)}`}>{d.status}</span>
                </div>
                <div class="mt-1 text-[12px] text-muted-foreground/80">{d.when}</div>
                <p class="mt-2 text-[13px] leading-relaxed text-muted-foreground">{d.note}</p>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="library" class="relative bg-background py-16">
    <div class="mx-auto max-w-6xl px-6">
      <a href="/regulations/circulars" class="mb-12 flex items-center justify-between gap-4 rounded-2xl border border-primary/25 bg-primary/[0.06] p-6 transition-colors hover:border-primary/50">
        <div>
          <div class="font-[var(--font-display)] text-lg font-semibold text-foreground">Looking for an older DGMS circular?</div>
          <p class="mt-1 text-sm text-muted-foreground">Search the Circular Finder — hundreds of DGMS circulars (1995–present), indexed to the exact compilation and page, each with its subject.</p>
        </div>
        <span class="shrink-0 rounded-full bg-primary px-5 py-2.5 text-[13px] font-semibold text-primary-foreground">Open Circular Finder →</span>
      </a>

      {featured.length > 0 && (
        <div id="featured-section" class="mb-14">
          <div class="mb-5 max-w-2xl">
            <span class="text-[11px] font-semibold uppercase tracking-[0.28em] text-primary">Start here</span>
            <h2 class="mt-2 font-[var(--font-display)] text-2xl font-bold tracking-tight text-foreground md:text-3xl">The cornerstones</h2>
            <p class="mt-2 text-sm text-muted-foreground">The core Acts, rules and codes that govern Indian coal mining. Everything else is in the full list below.</p>
          </div>
          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {featured.map((r) => (
              <a href={`/regulations/${r.slug}`}
                class="group flex flex-col rounded-2xl border border-primary/20 bg-primary/[0.04] p-5 transition-all hover:-translate-y-1 hover:border-primary/40">
                <div class="flex items-start justify-between gap-2">
                  <h3 class="font-[var(--font-display)] text-base font-semibold leading-snug text-foreground">{r.title}</h3>
                  <span class={`shrink-0 rounded-full px-2 py-0.5 text-[9px] font-semibold uppercase tracking-wide ${statusBadge(r.status)}`}>{statusLabel(r.status)}</span>
                </div>
                {r.summary && <p class="mt-2 line-clamp-3 flex-1 text-[13px] leading-relaxed text-muted-foreground">{r.summary}</p>}
                <span class="mt-3 text-[12px] font-semibold text-primary">Read &amp; download →</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="mb-6 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div class="max-w-2xl">
          <h2 class="font-[var(--font-display)] text-2xl font-bold tracking-tight text-foreground md:text-3xl">The full library</h2>
          <p class="mt-1 text-muted-foreground">Search {regs.length} regulations, circulars, notifications and codes across {cats.length} areas. Every entry has a hosted download and its official source.</p>
        </div>
        <input id="regsearch" type="search" placeholder="Search the library…" class="w-full rounded-xl border border-white/10 bg-white/[0.04] px-4 py-3 text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none md:w-72" aria-label="Search regulations" />
      </div>

      <div id="chips" class="mb-6 flex flex-wrap gap-2.5">
        <button class="chip active rounded-full border border-primary bg-primary px-4 py-2 text-[13px] font-semibold text-primary-foreground" data-cat="all">All</button>
        {cats.map((c) => (<button class="chip rounded-full border border-white/12 px-4 py-2 text-[13px] font-semibold text-muted-foreground transition-colors hover:border-primary" data-cat={c}>{CAT[c]}</button>))}
      </div>

      <div id="reglist" class="divide-y divide-white/[0.06] overflow-hidden rounded-2xl border border-white/10 bg-white/[0.02]">
        {regs.map((r) => (
          <a href={`/regulations/${r.slug}`} data-title={`${r.title} ${r.doc_number || ''} ${r.authority || ''}`.toLowerCase()} data-cat={r.category}
            class="regrow group flex items-center justify-between gap-4 px-5 py-3.5 transition-colors hover:bg-white/[0.04]">
            <div class="min-w-0">
              <div class="flex items-center gap-2">
                <span class="truncate font-medium text-foreground transition-colors group-hover:text-primary">{r.title}</span>
                {r.status !== 'in_force' && <span class={`shrink-0 rounded-full px-2 py-0.5 text-[9px] font-semibold uppercase tracking-wide ${statusBadge(r.status)}`}>{statusLabel(r.status)}</span>}
              </div>
              <div class="mt-0.5 flex flex-wrap items-center gap-x-2 text-[12px] text-muted-foreground/70">
                <span class="text-primary/70">{CAT[r.category]}</span>
                {r.authority && <span>· {r.authority}</span>}
                {r.issued_date && <span>· {r.issued_date}</span>}
              </div>
            </div>
            <span class="shrink-0 text-[13px] font-semibold text-muted-foreground transition-colors group-hover:text-primary">Open →</span>
          </a>
        ))}
      </div>
      <div class="mt-6 flex flex-col items-center gap-3">
        <button id="regmore" class="rounded-full border border-white/15 bg-white/[0.04] px-6 py-2.5 text-[13px] font-semibold text-foreground transition-colors hover:border-primary hover:text-primary">Show more</button>
        <p id="noresults" class="hidden py-4 text-center text-muted-foreground">No regulations match your search.</p>
        <p id="regcount" class="text-[12px] text-muted-foreground/60"></p>
      </div>
      {usingPlaceholder && <p class="mt-10 text-sm text-muted-foreground">Library is being populated — full catalogue lands shortly.</p>}
    </div>
  </section>

  <script>
    const PAGE = 30;
    const chips = document.querySelectorAll('#chips .chip');
    const rows = Array.from(document.querySelectorAll('#reglist .regrow')) as HTMLElement[];
    const search = document.getElementById('regsearch') as HTMLInputElement;
    const noresults = document.getElementById('noresults');
    const more = document.getElementById('regmore') as HTMLButtonElement;
    const featuredSection = document.getElementById('featured-section');
    const countEl = document.getElementById('regcount');
    let activeCat = 'all';
    let shown = PAGE;
    function apply() {
      const q = (search?.value || '').trim().toLowerCase();
      const filtered = rows.filter((r) => (activeCat === 'all' || r.dataset.cat === activeCat) && (!q || (r.dataset.title || '').includes(q)));
      rows.forEach((r) => { r.style.display = 'none'; });
      filtered.slice(0, shown).forEach((r) => { r.style.display = ''; });
      if (noresults) noresults.classList.toggle('hidden', filtered.length !== 0);
      if (more) more.style.display = filtered.length > shown ? '' : 'none';
      if (featuredSection) featuredSection.style.display = (q || activeCat !== 'all') ? 'none' : '';
      if (countEl) countEl.textContent = filtered.length ? `Showing ${Math.min(shown, filtered.length)} of ${filtered.length}` : '';
    }
    chips.forEach((chip) => chip.addEventListener('click', () => {
      chips.forEach((c) => { c.classList.remove('active','bg-primary','text-primary-foreground','border-primary'); c.classList.add('text-muted-foreground','border-white/12'); });
      chip.classList.add('active','bg-primary','text-primary-foreground','border-primary'); chip.classList.remove('text-muted-foreground','border-white/12');
      activeCat = (chip as HTMLElement).dataset.cat || 'all'; shown = PAGE; apply();
    }));
    search?.addEventListener('input', () => { shown = PAGE; apply(); });
    more?.addEventListener('click', () => { shown += PAGE; apply(); });
    apply();
  </script>
</Site>
