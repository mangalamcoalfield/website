---
import MagicSite from '../../layouts/MagicSite.astro';
import ShaderHero from '../../components/magic/ShaderHero.tsx';
import { SITE } from '../../data/site';
---
<MagicSite title="Contact">
  <ShaderHero
    client:load
    compact
    eyebrow="Contact"
    title="Get in touch"
    accentWords={1}
    description="For enquiries, partnerships or general questions, send us a message and we will be in touch."
  />

  <section class="mx-auto max-w-6xl px-6 py-24">
    <div class="grid gap-10 md:grid-cols-2">
      <!-- LEFT: visual-only form. This design-mirror page is not wired —
           the production /contact page has the real working form. -->
      <div>
        <span class="text-[11px] font-semibold uppercase tracking-[0.2em] text-primary">Send a message</span>
        <h2 class="mt-4 font-[var(--font-display)] text-3xl font-bold tracking-tight">We read every enquiry.</h2>
        <form onsubmit="event.preventDefault()" class="mt-8 grid gap-4">
          <input
            type="text"
            name="name"
            placeholder="Your full name"
            autocomplete="name"
            class="rounded-xl border border-white/10 bg-white/[0.04] px-4 py-3 text-foreground placeholder:text-muted-foreground focus:border-primary outline-none"
          />
          <input
            type="email"
            name="email"
            placeholder="you@example.com"
            autocomplete="email"
            class="rounded-xl border border-white/10 bg-white/[0.04] px-4 py-3 text-foreground placeholder:text-muted-foreground focus:border-primary outline-none"
          />
          <textarea
            name="message"
            rows="5"
            placeholder="How can we help?"
            class="rounded-xl border border-white/10 bg-white/[0.04] px-4 py-3 text-foreground placeholder:text-muted-foreground focus:border-primary outline-none"
          ></textarea>
          <label class="flex items-start gap-3 text-sm text-muted-foreground">
            <input type="checkbox" name="consent" class="mt-1 size-4 shrink-0 rounded border border-white/10 bg-white/[0.04] accent-primary" />
            <span>I consent to Mangalam Coalfield processing this information to respond to my enquiry, in line with the DPDP Act, 2023.</span>
          </label>
          <button type="submit" class="mt-2 w-fit rounded-full bg-primary px-7 py-3.5 text-sm font-semibold text-primary-foreground">
            Send message
          </button>
        </form>
        <p class="mt-5 text-xs text-muted-foreground">This is a design mirror — the form above is illustrative. On the live site it is fully wired and your message reaches our team.</p>
      </div>

      <!-- RIGHT: reach-us glass card -->
      <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-8 backdrop-blur-sm">
        <span class="text-[11px] font-semibold uppercase tracking-[0.2em] text-primary">Reach us</span>
        <h3 class="mt-5 font-[var(--font-display)] text-xl font-semibold tracking-tight">Operations</h3>
        <p class="mt-2 text-muted-foreground">{SITE.location}</p>
        <h3 class="mt-7 font-[var(--font-display)] text-xl font-semibold tracking-tight">Registered office</h3>
        <p class="mt-2 text-muted-foreground">Kolkata</p>
        <h3 class="mt-7 font-[var(--font-display)] text-xl font-semibold tracking-tight">Email</h3>
        <p class="mt-2 text-muted-foreground"><a href={`mailto:${SITE.hrEmail}`} class="text-primary">{SITE.hrEmail}</a></p>
        <h3 class="mt-7 font-[var(--font-display)] text-xl font-semibold tracking-tight">Employee Portal</h3>
        <p class="mt-2 text-muted-foreground"><a href={SITE.portalUrl} rel="noopener" class="text-primary">{SITE.portalUrl}</a></p>
      </div>
    </div>
  </section>
</MagicSite>
