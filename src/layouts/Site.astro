---
// Site.astro — PRODUCTION layout in the Magic design (green/lime on coal-black).
// Glass nav + scroll-progress + footer + Ask Mangalam bot, with full real SEO
// (canonical, OG, JSON-LD). Root nav links; indexable. Self-hosted fonts.
import '@fontsource/archivo/600.css';
import '@fontsource/archivo/700.css';
import '@fontsource/hanken-grotesk/400.css';
import '@fontsource/hanken-grotesk/500.css';
import '@fontsource/hanken-grotesk/600.css';
import '../styles/magic.css';
import AskMangalam from '../components/AskMangalam.astro';
import { SITE } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  jsonLd?: object | object[];
}
const { title, description = SITE.description, jsonLd } = Astro.props;
const fullTitle = title ? `${title} · ${SITE.name}` : `${SITE.name} — Mine Developer & Operator`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).href;
const ogImage = new URL('/og.png', Astro.site ?? Astro.url.origin).href;
const ldArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

const path = Astro.url.pathname;
const nav = [
  { href: '/about', label: 'About' },
  { href: '/operations', label: 'Operations' },
  { href: '/safety', label: 'Safety' },
  { href: '/learn', label: 'Learn' },
  { href: '/regulations', label: 'Regulations' },
  { href: '/cares', label: 'Cares' },
  { href: '/careers', label: 'Careers' },
  { href: '/contact', label: 'Contact' },
];
const active = (h: string) => (h === '/' ? path === '/' : path.startsWith(h));
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <meta name="theme-color" content="#06100b" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={SITE.name} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={ogImage} />
  {ldArray.map((obj) => (<script type="application/ld+json" set:html={JSON.stringify(obj)} />))}
</head>
<body class="bg-background text-foreground antialiased">
  <div id="prog" class="fixed inset-x-0 top-0 z-[1100] h-[3px] origin-left scale-x-0 bg-gradient-to-r from-primary/40 via-primary to-secondary"></div>

  <svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <symbol id="arrow" viewBox="0 0 24 24"><path d="M5 12h13M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/></symbol>
    <symbol id="check" viewBox="0 0 24 24"><path d="M4 12l5 5L20 6" stroke="currentColor" stroke-width="2.2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></symbol>
  </svg>

  <header id="mh" class="fixed inset-x-0 top-0 z-[1000] transition-all duration-300">
    <div class="mx-auto max-w-6xl px-4">
      <div id="mnav" class="mt-3 flex h-16 items-center justify-between rounded-2xl px-4 transition-all duration-300">
        <a href="/" class="flex items-center gap-2" aria-label={`${SITE.name} — home`}><img src="/mangalam_logo.png" alt={SITE.name} width="150" height="38" class="h-9 w-auto" /></a>
        <nav class="hidden items-center gap-7 md:flex" aria-label="Primary">
          {nav.map((i) => (<a href={i.href} class:list={["text-sm transition-colors hover:text-foreground", active(i.href) ? "text-foreground" : "text-muted-foreground"]}>{i.label}</a>))}
        </nav>
        <div class="hidden items-center gap-2 md:flex">
          <a href={SITE.portalUrl} rel="noopener" class="rounded-xl border border-white/15 bg-white/[0.04] px-4 py-2 text-[13px] font-semibold text-foreground transition-colors hover:border-primary hover:text-primary">Operations Portal <svg width="11" height="11" viewBox="0 0 24 24" fill="none" class="ml-0.5 inline-block align-[-1px]" aria-hidden="true"><path d="M7 17 17 7M9 7h8v8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
          <a href={SITE.mailUrl} aria-label="Employee Mail" title="Employee Mail" class="inline-flex items-center rounded-xl border border-white/15 bg-white/[0.04] p-[9px] text-foreground transition-colors hover:border-primary hover:text-primary"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg></a>
        </div>
        <button id="mb" class="flex flex-col gap-[5px] p-2 md:hidden" aria-label="Menu" aria-expanded="false"><span class="block h-0.5 w-5 bg-foreground"></span><span class="block h-0.5 w-5 bg-foreground"></span><span class="block h-0.5 w-5 bg-foreground"></span></button>
      </div>
    </div>
  </header>

  <nav id="mm" class="fixed inset-0 z-[999] flex translate-x-full flex-col justify-center gap-1 bg-background/95 px-9 backdrop-blur-lg transition-transform duration-300 md:hidden" aria-label="Mobile">
    {nav.map((i) => <a href={i.href} class="border-b border-white/10 py-3 font-[var(--font-display)] text-2xl font-semibold">{i.label}</a>)}
    <a href={SITE.portalUrl} rel="noopener" class="mt-4 inline-flex items-center gap-1.5 font-[var(--font-display)] text-2xl font-semibold text-primary">Operations Portal<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7M9 7h8v8"/></svg></a>
    <a href={SITE.mailUrl} rel="noopener" class="mt-2 inline-flex items-center gap-1.5 font-[var(--font-display)] text-2xl font-semibold text-primary">Employee Mail<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7M9 7h8v8"/></svg></a>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="border-t border-white/10 bg-white/[0.015] py-16 backdrop-blur-sm">
    <div class="mx-auto grid max-w-6xl grid-cols-2 gap-10 px-6 md:grid-cols-4">
      <div class="col-span-2 md:col-span-1">
        <img src="/mangalam_logo.png" alt={SITE.name} width="200" height="50" class="mb-4 h-12 w-auto" />
        <p class="max-w-xs text-sm leading-relaxed text-muted-foreground">{SITE.legalName} — Mine Developer &amp; Operator, Amlabad Colliery, Eastern Jharia, Jharkhand.</p>
      </div>
      <div>
        <h4 class="mb-4 text-[11px] font-semibold uppercase tracking-[0.12em] text-muted-foreground">Company</h4>
        {[['About','/about'],['Operations','/operations'],['Safety','/safety'],['Mangalam Cares','/cares'],['Careers','/careers']].map(([l,h]) => (<a href={h} class="mb-2.5 block text-sm text-foreground/80 transition-colors hover:text-primary">{l}</a>))}
      </div>
      <div>
        <h4 class="mb-4 text-[11px] font-semibold uppercase tracking-[0.12em] text-muted-foreground">Knowledge</h4>
        <a href="/learn" class="mb-2.5 block text-sm text-foreground/80 transition-colors hover:text-primary">How mining works</a>
        <a href="/contact" class="mb-2.5 block text-sm text-foreground/80 transition-colors hover:text-primary">Contact</a>
      </div>
      <div>
        <h4 class="mb-4 text-[11px] font-semibold uppercase tracking-[0.12em] text-muted-foreground">Contact</h4>
        <a href={`mailto:${SITE.hrEmail}`} class="mb-2.5 block text-sm text-foreground/80 transition-colors hover:text-primary">{SITE.hrEmail}</a>
        <a href={SITE.portalUrl} rel="noopener" class="mb-2.5 inline-flex items-center gap-1 text-sm text-foreground/80 transition-colors hover:text-primary">Operations Portal<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7M9 7h8v8"/></svg></a>
        <a href={SITE.mailUrl} rel="noopener" class="mb-2.5 inline-flex items-center gap-1 text-sm text-foreground/80 transition-colors hover:text-primary">Employee Mail<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7M9 7h8v8"/></svg></a>
      </div>
    </div>
    <div class="mx-auto mt-12 flex max-w-6xl flex-wrap justify-between gap-3 border-t border-white/10 px-6 pt-6 text-[13px] text-muted-foreground">
      <span>© 2026 {SITE.legalName}</span>
      <span>{SITE.location}</span>
    </div>
  </footer>

  <AskMangalam />

  <script>
    const mnav = document.getElementById('mnav');
    const prog = document.getElementById('prog');
    const onScroll = () => {
      const y = window.scrollY; const scrolled = y > 24;
      mnav?.classList.toggle('bg-background/60', scrolled);
      mnav?.classList.toggle('border', scrolled);
      mnav?.classList.toggle('border-white/10', scrolled);
      mnav?.classList.toggle('backdrop-blur-xl', scrolled);
      mnav?.classList.toggle('shadow-[0_18px_50px_-20px_rgba(0,0,0,.8)]', scrolled);
      const h = document.documentElement.scrollHeight - window.innerHeight;
      if (prog) prog.style.transform = `scaleX(${h > 0 ? y / h : 0})`;
    };
    addEventListener('scroll', onScroll, { passive: true }); onScroll();
    const mb = document.getElementById('mb'); const mm = document.getElementById('mm');
    mb?.addEventListener('click', () => {
      const open = mm?.classList.toggle('translate-x-full');
      mb.setAttribute('aria-expanded', String(open === false));
      document.body.style.overflow = open === false ? 'hidden' : '';
    });
    mm?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => { mm.classList.add('translate-x-full'); document.body.style.overflow=''; }));
  </script>
</body>
</html>
