---
import MagicSite from '../../layouts/MagicSite.astro';
import ShaderHero from '../../components/magic/ShaderHero.tsx';

// Learn — Magic × Pro Max mirror of the knowledge hub. The hero is the only
// React island; the NCI panel and entry grid are static Tailwind + magic.css.
const entries = [
  {
    cat: 'Operations',
    title: 'Bord & pillar mining',
    body: 'The underground method worked at Amlabad — driving a grid of roadways through the seam, leaving coal pillars to hold the roof, then extracting them in retreat.',
  },
  {
    cat: 'Safety · Ventilation',
    title: 'Mine gas & methane management',
    body: 'Why coal seams hold firedamp, how ventilation and continuous gas monitoring keep every shift safe, and how the same methane is captured rather than vented.',
  },
  {
    cat: 'Markets',
    title: 'Coal grades & the National Coal Index',
    body: 'How non-coking coal is graded by gross calorific value, and how the Ministry of Coal’s monthly National Coal Index tracks all-India price movement.',
  },
  {
    cat: 'Regulation',
    title: 'DGMS & the rules of the mine',
    body: 'The Directorate General of Mines Safety, the Mines Act and the Coal Mines Regulations 2017 — the statutory framework every working mine answers to.',
  },
];
---
<MagicSite title="Learn — How Coal Mining Works">
  <ShaderHero
    client:load
    compact
    eyebrow="Knowledge hub"
    title="How coal mining actually works"
    accentWords={2}
    description="A growing, plain-language reference on Indian coal mining — the engineering, the regulation, and the science. Built to inform, not to sell."
  />

  <!-- National Coal Index panel -->
  <section class="mx-auto max-w-6xl px-6 pt-16 md:pt-24">
    <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-8 backdrop-blur-sm">
      <span class="text-[11px] font-semibold uppercase tracking-[0.2em] text-primary">Markets · National Coal Index</span>
      <div class="mt-6 grid gap-8 sm:grid-cols-3">
        <div>
          <div class="text-[11px] uppercase tracking-wide text-muted-foreground">Latest NCI</div>
          <div class="mt-1.5 font-[var(--font-display)] text-4xl font-bold leading-none text-foreground">148.4</div>
        </div>
        <div>
          <div class="text-[11px] uppercase tracking-wide text-muted-foreground">Month on month</div>
          <div class="mt-1.5 font-[var(--font-display)] text-4xl font-bold leading-none text-primary">▲ 1.3</div>
        </div>
        <div>
          <div class="text-[11px] uppercase tracking-wide text-muted-foreground">Series</div>
          <div class="mt-1.5 text-base font-semibold text-foreground">Non-coking · all-India</div>
        </div>
      </div>
      <p class="mt-6 max-w-[60ch] text-sm leading-relaxed text-muted-foreground">
        The National Coal Index is published monthly by the Ministry of Coal. Source:
        <a href="https://coal.nic.in" rel="noopener" class="text-primary underline underline-offset-2 transition-colors hover:text-foreground">coal.nic.in</a>.
        It is a monthly index, not a live price.
      </p>
    </div>
  </section>

  <!-- Knowledge entries -->
  <section class="mx-auto max-w-6xl px-6 py-20 md:py-28">
    <div class="mb-10 max-w-2xl">
      <span class="text-[11px] font-semibold uppercase tracking-[0.2em] text-primary">Explainers &amp; sources</span>
      <h2 class="mt-3 font-[var(--font-display)] text-3xl font-bold text-foreground md:text-4xl">The reference library.</h2>
      <p class="mt-4 text-lg leading-relaxed text-muted-foreground">Curated explainers and version-dated links to canonical sources — DGMS, the Ministry of Coal, the Coal Mines Regulations 2017 and the Mines Act.</p>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      {entries.map((e) => (
        <a href="/mirror/learn" class="group rounded-2xl border border-white/10 bg-white/[0.04] p-6 backdrop-blur-sm transition hover:border-primary/30">
          <span class="text-[11px] uppercase tracking-wide text-primary">{e.cat}</span>
          <h3 class="mt-2 font-[var(--font-display)] text-lg font-semibold text-foreground">{e.title}</h3>
          <p class="mt-1.5 text-sm text-muted-foreground">{e.body}</p>
        </a>
      ))}
    </div>

    <p class="mt-12 max-w-[60ch] text-sm text-muted-foreground">
      Canonical articles and curated source links land here from the content track.
    </p>
  </section>
</MagicSite>
