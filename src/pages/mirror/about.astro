---
import MagicSite from '../../layouts/MagicSite.astro';
import ShaderHero from '../../components/magic/ShaderHero.tsx';
const base = '/mirror';
---
<MagicSite title="About & Leadership">
  <ShaderHero
    client:load
    compact
    eyebrow="About Mangalam"
    title="A foundation built to last"
    accentWords={1}
    description="Mangalam Coalfield Private Limited is a mine developer and operator reviving the historic Amlabad pits in Eastern Jharia, Jharkhand — built on legacy, run to standard, and committed to responsible coal and cleaner energy."
  />

  <!-- Our story + Chairman Emeritus tribute -->
  <section class="relative bg-background py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 md:grid-cols-2">
        <div>
          <span class="text-xs font-semibold uppercase tracking-[0.2em] text-primary">Our story</span>
          <h2 class="mt-4 font-[var(--font-display)] text-4xl font-bold text-foreground md:text-5xl">Carrying a vision forward.</h2>
          <div class="mt-6 space-y-4 text-muted-foreground leading-relaxed">
            <p>Mangalam stands on a foundation of rich legacy, resilience, and shared values — carrying forward the vision of its founder. A new generation now leads, committed to trust, integrity, and excellence in all it builds.</p>
            <p>Today, that commitment is expressed through the revival of the Amlabad block in Eastern Jharia: restoring historic underground coal workings and developing coal bed methane as a cleaner commercial energy stream from the same seams.</p>
            <p>The company operates to the Coal Mines Regulations 2017 and the Mines Act 1952, with qualified statutory officials in every mandated position. <em>(Placeholder copy — the full company history will be filled in from the content track.)</em></p>
          </div>
        </div>

        <div>
          <span class="text-xs font-semibold uppercase tracking-[0.2em] text-primary">In memoriam</span>
          <div class="mt-4 rounded-3xl border border-white/10 bg-white/[0.04] p-8 backdrop-blur-sm">
            <div class="flex aspect-[4/5] items-center justify-center rounded-2xl bg-gradient-to-br from-white/[0.06] via-primary/[0.04] to-transparent text-center text-sm leading-relaxed text-muted-foreground">
              Portrait — to be supplied
            </div>
            <div class="mt-6">
              <div class="font-[var(--font-display)] text-xl font-semibold text-foreground">Late Shree Gopal Agarwal</div>
              <div class="mt-1 text-primary text-xs uppercase tracking-wide">Chairman Emeritus</div>
              <p class="mt-4 italic text-muted-foreground">Guided by his visionary leadership, the Mangalam family remains deeply committed to upholding trust, integrity, and excellence — the values on which the company was built and continues to grow.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What guides us -->
  <section class="relative bg-background py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="max-w-2xl">
        <span class="text-xs font-semibold uppercase tracking-[0.2em] text-primary">What guides us</span>
        <h2 class="mt-4 font-[var(--font-display)] text-4xl font-bold text-foreground md:text-5xl">Trust, integrity, excellence.</h2>
        <p class="mt-4 text-muted-foreground leading-relaxed">The values carried forward by a new generation of leadership.</p>
      </div>
      <div class="mt-12 grid gap-5 md:grid-cols-3">
        <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-8 backdrop-blur-sm">
          <span class="text-primary text-sm font-semibold">01</span>
          <h3 class="mt-3 font-[var(--font-display)] text-xl font-semibold text-foreground">Trust</h3>
          <p class="mt-3 text-sm text-muted-foreground">Earned through consistency — with our workforce, our partners, and the communities around the mine.</p>
        </div>
        <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-8 backdrop-blur-sm">
          <span class="text-primary text-sm font-semibold">02</span>
          <h3 class="mt-3 font-[var(--font-display)] text-xl font-semibold text-foreground">Integrity</h3>
          <p class="mt-3 text-sm text-muted-foreground">Operating to statute and to our word, with safety and compliance treated as the baseline.</p>
        </div>
        <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-8 backdrop-blur-sm">
          <span class="text-primary text-sm font-semibold">03</span>
          <h3 class="mt-3 font-[var(--font-display)] text-xl font-semibold text-foreground">Excellence</h3>
          <p class="mt-3 text-sm text-muted-foreground">Engineering rigour and discipline on every shift, underground and above ground.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Leadership -->
  <section class="relative bg-background py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="max-w-2xl">
        <span class="text-xs font-semibold uppercase tracking-[0.2em] text-primary">Leadership</span>
        <h2 class="mt-4 font-[var(--font-display)] text-4xl font-bold text-foreground md:text-5xl">The team taking it forward.</h2>
        <p class="mt-4 text-muted-foreground leading-relaxed">Current leadership profiles will be published here from the content track.</p>
      </div>
      <div class="mt-12 grid gap-5 md:grid-cols-3">
        <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-8 backdrop-blur-sm">
          <div class="font-[var(--font-display)] text-xl font-semibold text-foreground">Leadership profile</div>
          <div class="mt-1 text-primary text-xs uppercase tracking-wide">Director</div>
          <p class="mt-4 text-sm text-muted-foreground">Profile and bio to be supplied.</p>
        </div>
        <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-8 backdrop-blur-sm">
          <div class="font-[var(--font-display)] text-xl font-semibold text-foreground">Leadership profile</div>
          <div class="mt-1 text-primary text-xs uppercase tracking-wide">Director</div>
          <p class="mt-4 text-sm text-muted-foreground">Profile and bio to be supplied.</p>
        </div>
        <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-8 backdrop-blur-sm">
          <div class="font-[var(--font-display)] text-xl font-semibold text-foreground">Leadership profile</div>
          <div class="mt-1 text-primary text-xs uppercase tracking-wide">Statutory Head</div>
          <p class="mt-4 text-sm text-muted-foreground">Profile and bio to be supplied.</p>
        </div>
      </div>
    </div>
  </section>
</MagicSite>
