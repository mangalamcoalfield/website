---
// Password-gated admin view of job applications. Standalone (no marketing nav),
// noindex. Fetches from /api/admin-applications with the password entered here.
import '../../styles/magic.css';
export const prerender = false;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Applications — Admin · Mangalam Coalfield</title>
</head>
<body class="bg-background text-foreground antialiased">
  <div id="gate" class="mx-auto flex min-h-screen max-w-sm flex-col justify-center px-6">
    <span class="text-[11px] font-semibold uppercase tracking-[0.28em] text-primary">Admin</span>
    <h1 class="mt-2 font-[var(--font-display)] text-3xl font-bold">Job applications</h1>
    <p class="mt-2 text-sm text-muted-foreground">Enter the admin password to view submitted applications.</p>
    <form id="pwform" class="mt-6 flex flex-col gap-3">
      <input id="pw" type="password" placeholder="Admin password" autocomplete="current-password"
        class="rounded-xl border border-white/10 bg-white/[0.04] px-4 py-3 text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none" />
      <button type="submit" class="rounded-xl bg-primary px-5 py-3 text-sm font-semibold text-primary-foreground">View applications</button>
      <p id="err" class="text-sm text-[#e08a6a]"></p>
    </form>
  </div>

  <div id="view" hidden class="mx-auto max-w-6xl px-6 py-12">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <h1 class="font-[var(--font-display)] text-3xl font-bold">Applications <span id="count" class="text-muted-foreground"></span></h1>
      <button id="refresh" class="rounded-xl border border-white/15 bg-white/[0.04] px-4 py-2 text-[13px] font-semibold transition-colors hover:border-primary hover:text-primary">Refresh</button>
    </div>
    <div id="list" class="mt-6 flex flex-col gap-3"></div>
    <p id="empty" class="hidden py-12 text-center text-muted-foreground">No applications yet.</p>
  </div>

  <script>
    const gate = document.getElementById('gate')!;
    const view = document.getElementById('view')!;
    const form = document.getElementById('pwform') as HTMLFormElement;
    const pw = document.getElementById('pw') as HTMLInputElement;
    const err = document.getElementById('err')!;
    const list = document.getElementById('list')!;
    const countEl = document.getElementById('count')!;
    const empty = document.getElementById('empty')!;
    let password = '';

    const esc = (s: unknown) => String(s ?? '').replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c] as string));

    async function load() {
      const r = await fetch('/api/admin-applications', {
        method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ password }),
      });
      const data = await r.json().catch(() => ({}));
      if (r.status === 401) { err.textContent = 'Incorrect password.'; return false; }
      if (!data.ok) { err.textContent = data.error === 'not_configured' || data.error === 'no_password_set' ? 'Admin view is not configured yet (missing SUPABASE_SERVICE_KEY / ADMIN_PASSWORD).' : 'Could not load applications.'; return false; }
      gate.hidden = true; view.hidden = false;
      countEl.textContent = `(${data.count})`;
      empty.classList.toggle('hidden', data.count !== 0);
      list.innerHTML = (data.applications || []).map((a: any) => {
        const d = a.details || {};
        const detailRows = Object.keys(d).map((k) => `<span class="rounded bg-white/[0.05] px-2 py-0.5 text-[12px] text-muted-foreground"><span class="text-foreground/60">${esc(k)}:</span> ${esc(d[k])}</span>`).join(' ');
        const when = a.created_at ? new Date(a.created_at).toLocaleString() : '';
        return `<div class="rounded-2xl border border-white/10 bg-white/[0.04] p-5">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
              <div class="font-[var(--font-display)] text-lg font-semibold">${esc(a.name)} <span class="text-sm font-normal text-primary">· ${esc(a.role)}</span></div>
              <div class="mt-1 text-[13px] text-muted-foreground">${esc(a.email)}${a.phone ? ' · ' + esc(a.phone) : ''} · <span class="text-muted-foreground/60">${esc(when)}</span></div>
            </div>
            ${a.resume ? `<a href="${esc(a.resume)}" target="_blank" rel="noopener" class="shrink-0 rounded-xl border border-white/15 bg-white/[0.04] px-4 py-2 text-[13px] font-semibold hover:border-primary hover:text-primary">Résumé ↗</a>` : ''}
          </div>
          ${detailRows ? `<div class="mt-3 flex flex-wrap gap-2">${detailRows}</div>` : ''}
        </div>`;
      }).join('');
      return true;
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault(); err.textContent = ''; password = pw.value;
      await load();
    });
    document.getElementById('refresh')!.addEventListener('click', load);
  </script>
</body>
</html>
