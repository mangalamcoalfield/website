---
import Site from '../layouts/Site.astro';
import ShaderHero from '../components/magic/ShaderHero.tsx';
import { Safety } from '../components/magic/MagicSections.tsx';

const pillars = [
  { ix: '01', title: 'Statutory positions', body: 'DGMS-mandated officials — manager, safety officer, surveyors and engineers — appointed and certified for every district.' },
  { ix: '02', title: 'Registers & records', body: 'Statutory registers maintained and equipment tested on schedule, with structured reporting.' },
  { ix: '03', title: 'Gas & ventilation', body: 'Ventilation discipline and gas monitoring keep the air safe underground. We teach the science publicly; we never publish site-specific readings.' },
  { ix: '04', title: 'Workforce medicals', body: 'Periodic medical examinations and competency tracking for own and contractor labour.' },
];
---
<Site title="Safety & Compliance" description="DGMS focus, statutory positions, registers, gas and ventilation discipline, and workforce medicals — how Mangalam treats statutory safety as the condition for permission to operate.">
  <ShaderHero
    client:load
    compact
    eyebrow="Safety & compliance"
    title="The condition for permission to operate"
    accentWords={3}
    description="Underground coal mining carries real risk. We treat statutory safety as the baseline, not an afterthought — and as the condition for our permission to operate."
  />
  <Safety client:visible />

  <section class="relative bg-background py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-12 max-w-2xl">
        <span class="text-[11px] font-semibold uppercase tracking-[0.28em] text-primary">How it works in practice</span>
        <h2 class="mt-3 font-[var(--font-display)] text-4xl font-bold tracking-tight text-foreground md:text-5xl">The pillars of our safety system.</h2>
        <p class="mt-4 max-w-2xl text-muted-foreground">A plain summary of the statutory disciplines that govern underground operations — the DGMS framework we operate within as a minimum.</p>
      </div>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
        {pillars.map((p) => (
          <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-7 backdrop-blur-sm transition-all hover:-translate-y-1 hover:border-primary/30">
            <span class="font-[var(--font-display)] text-sm font-bold text-primary">{p.ix}</span>
            <h3 class="mt-4 font-[var(--font-display)] text-lg font-semibold text-foreground">{p.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{p.body}</p>
          </div>
        ))}
      </div>
      <div class="mt-10 flex flex-wrap gap-x-8 gap-y-3">
        <a href="/learn/dgms-and-the-rules-of-the-mine" class="inline-flex items-center gap-2 text-sm font-semibold text-primary transition-colors hover:text-secondary">
          DGMS &amp; the rules of the mine
          <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"><use href="#arrow"/></svg>
        </a>
        <a href="/learn/mine-gas-and-methane-management" class="inline-flex items-center gap-2 text-sm font-semibold text-primary transition-colors hover:text-secondary">
          Mine gas &amp; methane management
          <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"><use href="#arrow"/></svg>
        </a>
        <a href="/regulations" class="inline-flex items-center gap-2 text-sm font-semibold text-primary transition-colors hover:text-secondary">
          The regulations hub
          <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"><use href="#arrow"/></svg>
        </a>
      </div>
    </div>
  </section>

  <section class="relative bg-background pb-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="rounded-3xl border border-primary/20 bg-primary/[0.05] p-8 md:p-10">
        <span class="text-[11px] font-semibold uppercase tracking-[0.28em] text-primary">Safety at Amlabad</span>
        <p class="mt-4 max-w-3xl text-[17px] leading-8 text-foreground/90">Amlabad is an underground coking-coal mine, and underground coking-coal seams are gassy by nature. That is precisely why every statutory position, register, ventilation plan and gas check exists — and why we treat them as non-negotiable rather than as paperwork. We teach the science of mine gas and ventilation openly; we never publish site-specific readings, plans or figures.</p>
      </div>
    </div>
  </section>
</Site>
