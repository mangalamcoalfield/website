---
import MirrorLayout from '../../layouts/MirrorLayout.astro';
const base = '/mirror';
---
<MirrorLayout title="Safety & Compliance">
  <!-- HERO -->
  <section class="phero">
    <div class="wrap">
      <span class="eyebrow reveal in">Safety &amp; compliance</span>
      <h1 class="reveal in">The condition for <span class="u">permission</span> to operate.</h1>
      <p class="lead reveal in">Underground coal mining carries real risk. We treat statutory safety as the baseline, not an afterthought — and as the condition for our permission to operate.</p>
    </div>
  </section>

  <!-- STANDARD (split: checklist + metric) -->
  <section class="block" style="padding-top:0">
    <div class="wrap">
      <div class="split">
        <div class="reveal">
          <span class="eyebrow">Our standard</span>
          <h2 style="margin-top:18px">Statutory safety, every shift.</h2>
          <p class="lead" style="margin-top:18px">The Directorate General of Mines Safety (DGMS) sets the framework for Indian coal mining. We operate within it as a minimum.</p>
          <ul class="checklist">
            <li><svg class="ck" viewBox="0 0 24 24"><use href="#check"/></svg>Qualified statutory officials across all DGMS-mandated positions</li>
            <li><svg class="ck" viewBox="0 0 24 24"><use href="#check"/></svg>Maintained statutory registers and periodic equipment testing</li>
            <li><svg class="ck" viewBox="0 0 24 24"><use href="#check"/></svg>Gas monitoring, ventilation discipline, and roof-support standards</li>
            <li><svg class="ck" viewBox="0 0 24 24"><use href="#check"/></svg>Medical examinations and competency tracking for the workforce</li>
          </ul>
        </div>
        <div class="glass metric reveal">
          <div class="big">Zero</div>
          <div class="cap">compromise on the standards that keep people safe underground.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- PILLARS (bento 4) -->
  <section class="block">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow">How it works in practice</span>
        <h2>The pillars of our safety system.</h2>
        <p class="lead">A plain summary of the statutory disciplines that govern underground operations. Detailed write-ups will be published from the content track.</p>
      </div>
      <div class="bento stagger reveal">
        <div class="glass glass-hover cell col-4"><span class="ix">01</span><h3>Statutory positions</h3><p>DGMS-mandated officials — manager, safety officer, surveyors and engineers — appointed and certified for every district.</p></div>
        <div class="glass glass-hover cell col-4"><span class="ix">02</span><h3>Registers &amp; records</h3><p>Statutory registers maintained and equipment tested on schedule, with structured reporting.</p></div>
        <div class="glass glass-hover cell col-4"><span class="ix">03</span><h3>Gas &amp; ventilation</h3><p>Ventilation discipline and gas monitoring keep the air safe underground. (We teach the science publicly; we never publish site-specific readings.)</p></div>
        <div class="glass glass-hover cell col-4"><span class="ix">04</span><h3>Workforce medicals</h3><p>Periodic medical examinations and competency tracking for own and contractor labour.</p></div>
      </div>
      <div class="reveal" style="margin-top:40px">
        <a class="tlink" href={`${base}/learn`}>Learn about DGMS &amp; the rules of the mine <svg width="18" height="18"><use href="#arrow"/></svg></a>
      </div>
    </div>
  </section>
</MirrorLayout>
