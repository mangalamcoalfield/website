# Public (client-exposed) Supabase config — safe to ship to the browser.
# Astro exposes only PUBLIC_-prefixed vars to client code.
PUBLIC_SUPABASE_URL=https://cxxocuprqztejsxqznye.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server-only secret (sb_secret_…). NEVER commit. NEVER expose to the client.
# Used only by edge functions / build scripts. Leave blank locally if unused.
# SUPABASE_SECRET_KEY=

# --- Ask Mangalam bot (Vercel, SERVER-ONLY — do NOT prefix with PUBLIC_) ------
# Set in Vercel env (Production/Preview), never in client code or git.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash-lite   # optional override (free-tier Flash-Lite)

# --- Careers email pipeline (Supabase Edge Function SECRETS) ------------------
# Set with: supabase secrets set NAME=value   (NOT in this .env / not in git)
#   RESEND_API_KEY=                 # OR the SMTP_* set below
#   SMTP_HOST= SMTP_PORT=465 SMTP_USER= SMTP_PASS=
#   FROM_EMAIL=careers@mangalamcoal.com   HR_EMAIL=hr@mangalamcoal.com
#   WEBHOOK_SECRET=                 # optional shared secret (also store in Vault)
#   RETENTION_DAYS=30               # résumé grace window before purge
