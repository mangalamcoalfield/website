---
import Site from '../layouts/Site.astro';
import ShaderHero from '../components/magic/ShaderHero.tsx';
import { SITE } from '../data/site';
---
<Site title="Privacy Notice" description="How Mangalam Coalfield Private Limited collects and processes personal data submitted through this website, under the Digital Personal Data Protection Act, 2023.">
  <ShaderHero client:load compact eyebrow="Legal" title="Privacy notice" accentWords={1} />

  <section class="relative bg-background pb-28 pt-4">
    <article class="mx-auto max-w-3xl px-6 text-[16px] leading-8 text-muted-foreground">
      <p class="mb-4"><em>Placeholder notice — to be reviewed and finalised by the company before launch.</em></p>

      <h2 class="mt-10 mb-3 font-[var(--font-display)] text-2xl font-bold text-foreground">Who we are</h2>
      <p class="mb-4">{SITE.legalName} ("Mangalam", "we") operates this website. For privacy questions, contact <a class="text-primary underline" href={`mailto:${SITE.hrEmail}`}>{SITE.hrEmail}</a>.</p>

      <h2 class="mt-10 mb-3 font-[var(--font-display)] text-2xl font-bold text-foreground">What we collect</h2>
      <p class="mb-4">When you submit a form on this site we collect the details you provide:</p>
      <ul class="mb-4 ml-5 list-disc">
        <li class="mb-2"><strong>Contact / enquiry form:</strong> your name, email and message.</li>
        <li class="mb-2"><strong>Careers application:</strong> your name, email, phone, the role applied for, and your résumé file.</li>
      </ul>

      <h2 class="mt-10 mb-3 font-[var(--font-display)] text-2xl font-bold text-foreground">Why we collect it &amp; your consent</h2>
      <p class="mb-4">We process this data only to respond to your enquiry or to consider your job application. We collect it on the basis of the consent you give via the checkbox on each form, in line with the Digital Personal Data Protection Act, 2023 (DPDP Act).</p>

      <h2 class="mt-10 mb-3 font-[var(--font-display)] text-2xl font-bold text-foreground">How long we keep it</h2>
      <p class="mb-4">Application data and résumés are retained only as long as needed for the recruitment process, then purged after a short grace window. Enquiry data is kept only as long as needed to respond and follow up.</p>

      <h2 class="mt-10 mb-3 font-[var(--font-display)] text-2xl font-bold text-foreground">Your rights</h2>
      <p class="mb-4">You may ask us to access, correct or delete the personal data you have submitted. To do so, email <a class="text-primary underline" href={`mailto:${SITE.hrEmail}`}>{SITE.hrEmail}</a>.</p>

      <h2 class="mt-10 mb-3 font-[var(--font-display)] text-2xl font-bold text-foreground">Sharing</h2>
      <p class="mb-4">We do not sell your data. Form submissions are stored securely and are accessible only to authorised personnel for the purpose above.</p>
    </article>
  </section>
</Site>
