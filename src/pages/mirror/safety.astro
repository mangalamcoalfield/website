---
import MagicSite from '../../layouts/MagicSite.astro';
import ShaderHero from '../../components/magic/ShaderHero.tsx';
import { Safety } from '../../components/magic/MagicSections.tsx';

const pillars = [
  { ix: '01', title: 'Statutory positions', body: 'DGMS-mandated officials — manager, safety officer, surveyors and engineers — appointed and certified for every district.' },
  { ix: '02', title: 'Registers & records', body: 'Statutory registers maintained and equipment tested on schedule, with structured reporting.' },
  { ix: '03', title: 'Gas & ventilation', body: 'Ventilation discipline and gas monitoring keep the air safe underground. We teach the science publicly; we never publish site-specific readings.' },
  { ix: '04', title: 'Workforce medicals', body: 'Periodic medical examinations and competency tracking for own and contractor labour.' },
];
---
<MagicSite title="Safety & Compliance">
  <ShaderHero
    client:load
    compact
    eyebrow="Safety & compliance"
    title="The condition for permission to operate"
    accentWords={2}
    description="Underground coal mining carries real risk. We treat statutory safety as the baseline, not an afterthought — and as the condition for our permission to operate."
  />
  <Safety client:visible />

  <section class="relative bg-background py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-12 max-w-2xl">
        <span class="text-[11px] font-semibold uppercase tracking-[0.28em] text-primary">How it works in practice</span>
        <h2 class="mt-3 font-[var(--font-display)] text-4xl font-bold tracking-tight text-foreground md:text-5xl">The pillars of our safety system.</h2>
        <p class="mt-4 max-w-2xl text-muted-foreground">A plain summary of the statutory disciplines that govern underground operations — the DGMS framework we operate within as a minimum.</p>
      </div>
      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
        {pillars.map((p) => (
          <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-7 backdrop-blur-sm transition hover:border-primary/30">
            <span class="font-[var(--font-display)] text-sm font-bold text-primary">{p.ix}</span>
            <h3 class="mt-4 font-[var(--font-display)] text-lg font-semibold text-foreground">{p.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</MagicSite>
