---
import { SITE } from '../data/site';
const year = 2026;
---
<footer>
  <div class="wrap">
    <div class="foot-grid">
      <div class="fb">
        <img src="/mangalam_logo.png" alt={SITE.name} width="250" height="64" />
        <p>{SITE.legalName} — Mine Developer &amp; Operator, Amlabad Colliery, Eastern Jharia, Jharkhand.</p>
      </div>
      <div>
        <h4>Company</h4>
        <a href="/about">About &amp; Leadership</a>
        <a href="/operations">Operations</a>
        <a href="/safety">Safety &amp; Compliance</a>
        <a href="/cares">Mangalam Cares</a>
        <a href="/careers">Careers</a>
      </div>
      <div>
        <h4>Knowledge</h4>
        <a href="/learn">How mining works</a>
        <a href="/learn?category=regulation">Regulation</a>
        <a href="/learn?category=markets">National Coal Index</a>
        <a href="/contact">Contact</a>
      </div>
      <div>
        <h4>Contact</h4>
        <a href={`mailto:${SITE.hrEmail}`}>{SITE.hrEmail}</a>
        <a href={SITE.portalUrl} rel="noopener">Employee Portal ↗</a>
        <a href="/contact">{SITE.location}</a>
        <a href="/contact">{SITE.regOffice}</a>
      </div>
    </div>
    <div class="foot-bottom">
      <span>© {year} {SITE.legalName}</span>
      <span>Public corporate &amp; knowledge site · CIN and statutory details to follow</span>
    </div>
  </div>
</footer>
