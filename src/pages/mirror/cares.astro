---
import MirrorLayout from '../../layouts/MirrorLayout.astro';
const base = '/mirror';
---
<MirrorLayout title="Mangalam Cares">
  <!-- HERO -->
  <section class="phero">
    <div class="wrap">
      <span class="eyebrow reveal in">Mangalam Cares</span>
      <h1 class="reveal in">The work <span class="u">above ground</span> matters too.</h1>
      <p class="lead reveal in">Beyond production, Mangalam invests in the people and the environment around the mine — community welfare and the land we operate on. We showcase our own contributions: completed work with evidence, and planned work clearly labelled.</p>
    </div>
  </section>

  <!-- CSR PROGRAMMES (bento) -->
  <section class="block" style="padding-top:0">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow">Our contributions</span>
        <h2>Completed work, shown with evidence.</h2>
        <p class="lead">A focused set of programmes — community welfare and skills training already underway, with green cover and water management planned next. Completed work carries evidence; planned work is labelled as such.</p>
      </div>
      <div class="bento stagger reveal">
        <div class="glass glass-hover cell col-4">
          <span class="pill done">Completed</span>
          <h3>Community welfare around Amlabad</h3>
          <p>Local engagement and welfare initiatives in the villages around the Amlabad block.</p>
        </div>
        <div class="glass glass-hover cell col-4">
          <span class="pill done">Completed</span>
          <h3>Skill &amp; safety training</h3>
          <p>Investment in workforce training and safety awareness for own and contractor labour.</p>
        </div>
        <div class="glass glass-hover cell col-4">
          <span class="pill plan">Planned</span>
          <h3>Green cover &amp; reclamation</h3>
          <p>Plantation and land-care contributions in the mine vicinity (planned).</p>
        </div>
        <div class="glass glass-hover cell col-4">
          <span class="pill plan">Planned</span>
          <h3>Water &amp; environment management</h3>
          <p>Responsible water management and dust-control measures (planned).</p>
        </div>
      </div>
      <p class="note reveal" style="margin-top:48px;font-size:14px;color:var(--on-dark-mut);padding-top:24px;border-top:1px solid var(--line)">Placeholder programmes shown. Real CSR write-ups — with evidence for completed work — will be published from the content track.</p>
      <div class="reveal" style="margin-top:30px"><a class="tlink" href={base}>Back to overview <svg width="18" height="18"><use href="#arrow"/></svg></a></div>
    </div>
  </section>
</MirrorLayout>
